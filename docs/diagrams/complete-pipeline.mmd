flowchart TD
    subgraph EtendoDB["Etendo PostgreSQL Database"]
        AD["AD Metadata<br/>(Windows, Tabs, Columns,<br/>Processes, Reports, References)"]
    end

    subgraph EntryPoint["0. ENTRY POINT (CLI — Node.js)"]
        CACHE["menu-cache.js<br/>(ad-menu-cache.json)<br/>search / refresh / list"]
        MENU["resolve-menu.js<br/>(--menu-id / --menu-name)<br/>cache-first, DB fallback"]
        PIPE["pipeline.js<br/>(orchestrator)<br/>--skip-interactive / --skip-to"]
        FORM_INFO["Form detected (action X)<br/>Shows Java + HTML source paths<br/>(manual build required)"]
    end

    subgraph Extraction["1. EXTRACTION (CLI — Node.js)"]
        EXT["extract-from-db.js<br/>extract-fields.js<br/>extract-rules.js"]
        PEXT["extract-from-process.js<br/>(processes + reports)"]
        RAW_S["schema-raw.json<br/>(all fields, FK refs, callouts)"]
        RAW_R["rules-raw.json<br/>(all business rules)"]
        RAW_P["process-raw.json / report-raw.json<br/>(metadata + parameters)"]
    end

    subgraph PreClassify["2. PRE-CLASSIFICATION (CLI + AI)"]
        PC["pre-classify.js"]
        CLASS_R["rules-classified.json<br/>(~60% auto-classified)"]
    end

    subgraph Curation["3. CURATION (Human + Decision UI)"]
        DP["Decision Panel<br/>(React — port 5174)"]
        CUR_S["schema-curated.json<br/>(visibility decided)"]
        CUR_R["rules-curated.json<br/>(disposition decided)"]
    end

    subgraph Validation["4. VALIDATION (CLI)"]
        VAL["validate-schema.js<br/>4 levels: structural,<br/>semantic, visibility,<br/>cross-reference"]
    end

    subgraph ContractGen["5. CONTRACT GENERATION (CLI)"]
        GC["generate-contract.js<br/>(windows, processes, reports)"]
        CONTRACT["contract.json<br/>(single source of truth)"]
    end

    subgraph BackendConfig["6. BACKEND CONFIGURATION"]
        PTN["push-to-neo.js<br/>+ neo-writer.js<br/>(specType W / P / R)"]
        TABLES["ETGO_SF_SPEC<br/>ETGO_SF_ENTITY<br/>ETGO_SF_FIELD"]
    end

    subgraph FrontendGen["7. FRONTEND GENERATION (CLI)"]
        GF["generate-frontend.js<br/>(windows, processes, reports)"]
        GM["generate-mock-data.js"]
        REACT["React SPA components"]
        MOCK["mockData.js<br/>mockCatalogs.js"]
    end

    subgraph TodoTranslation["7b. TODO TRANSLATION (AI-assisted)"]
        TT["translate-todos.js<br/>(interactive, AI-assisted)"]
        TT_OUT["React components with<br/>translated callout/onchange logic"]
    end

    subgraph Runtime["8. RUNTIME (NEO Headless — Java)"]
        NEO["NeoServlet<br/>/sws/neo/*"]
        AUTH["JWT Authentication"]
        RESOLVE["Spec + Entity Resolution"]
        FILTER["NeoFieldFilter<br/>(CRUD field filtering)"]
        HANDLER["NeoHandler CDI Hook<br/>(optional custom logic)"]
        DS["DefaultJsonDataService<br/>(Etendo CRUD fallback)"]
        SEL["NeoSelectorService<br/>(FK dropdowns)"]
        PROC["NeoProcessService<br/>(process execution)"]
        RPT["NeoReportService<br/>(Jasper report generation:<br/>PDF, XLS, CSV, HTML)"]
    end

    subgraph Testing["TESTING"]
        CT["Contract Tests<br/>(Node.js — instant)"]
        IT["Integration Tests<br/>(JUnit + OBBaseTest<br/>in Etendo Go)"]
    end

    subgraph Client["API Consumer"]
        APP["React SPA / Mobile App / External Client"]
    end

    %% Entry point: cache → menu resolution → pipeline orchestrator
    AD -->|"refresh (on miss)"| CACHE
    CACHE -->|cached entries| MENU
    MENU -->|"action W"| PIPE
    MENU -->|"action P"| PIPE
    MENU -->|"action R"| PIPE
    MENU -->|"action X (form)"| FORM_INFO

    %% Pipeline dispatches to correct extraction
    PIPE -->|window mode| EXT
    PIPE -->|process mode| PEXT
    PIPE -->|report mode| PEXT

    %% Window extraction
    AD -->|SQL queries| EXT
    EXT --> RAW_S
    EXT --> RAW_R

    %% Process/report extraction
    AD -->|SQL queries| PEXT
    PEXT --> RAW_P

    %% Process/report pipeline (simplified: extract → contract → push → frontend)
    RAW_P -->|process/report mode| GC

    %% Pre-classification (windows only)
    RAW_R --> PC
    PC --> CLASS_R

    %% Curation (windows only)
    RAW_S --> DP
    CLASS_R --> DP
    DP --> CUR_S
    DP --> CUR_R

    %% Validation (windows only)
    CUR_S --> VAL
    VAL -->|fail| DP
    VAL -->|pass| GC

    %% Contract generation (single source of truth)
    CUR_R --> GC
    GC --> CONTRACT

    %% Backend: contract → push-to-neo → direct DB → NEO Headless
    CONTRACT -->|"visibility, apiPrediction,<br/>specType (W/P/R)"| PTN
    PTN -->|direct SQL INSERT/UPDATE| TABLES

    %% Frontend: contract → React SPA + mock data
    CONTRACT -->|"types, inputMode, callouts,<br/>displayLogic, apiPrediction"| GF
    CONTRACT --> GM
    GF --> REACT
    GM --> MOCK

    %% TODO Translation (windows only, after frontend generation)
    REACT --> TT
    TT --> TT_OUT

    %% Runtime
    TABLES --> NEO
    NEO --> AUTH
    AUTH --> RESOLVE
    RESOLVE --> FILTER
    FILTER --> HANDLER
    HANDLER -->|custom response| APP
    HANDLER -->|null = fallthrough| DS
    DS --> APP
    RESOLVE --> SEL
    RESOLVE --> PROC
    RESOLVE --> RPT
    SEL --> APP
    PROC --> APP
    RPT -->|binary PDF/XLS/CSV/HTML| APP

    %% Testing
    CONTRACT --> CT

    %% Styling
    classDef db fill:#4a90d9,stroke:#2c5f8a,color:white
    classDef cli fill:#f5a623,stroke:#c47d0e,color:white
    classDef human fill:#7ed321,stroke:#5a9a18,color:white
    classDef webhook fill:#d0021b,stroke:#a00216,color:white
    classDef runtime fill:#9013fe,stroke:#6b0ebf,color:white
    classDef artifact fill:#e8e8e8,stroke:#999,color:#333
    classDef test fill:#50e3c2,stroke:#2db89e,color:white
    classDef client fill:#bd10e0,stroke:#8a0ca5,color:white
    classDef entry fill:#ff6b6b,stroke:#c0392b,color:white

    class AD db
    class EXT,PEXT,PC,VAL cli
    class DP human
    class NEO,AUTH,RESOLVE,FILTER,HANDLER,DS,SEL,PROC,RPT runtime
    class RAW_S,RAW_R,RAW_P,CLASS_R,CUR_S,CUR_R,TABLES,CONTRACT,REACT,MOCK artifact
    class CT,IT test
    class APP client
    class GC,PTN,GF,GM,TT cli
    class TT_OUT artifact
    class CACHE,MENU,PIPE entry
    class FORM_INFO human
