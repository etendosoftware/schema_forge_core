{
  "name": "@etendosoftware/app-shell-core",
  "version": "0.3.0",
  "description": "Reusable Schema Forge app shell runtime without generated contracts or windows.",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "sideEffects": [
    "./src/styles.css"
  ],
  "exports": {
    ".": "./src/index.js",
    "./auth": "./src/auth/index.js",
    "./i18n": "./src/i18n/index.js",
    "./i18n/resolveLabel": "./src/i18n/resolveLabel.js",
    "./layout": "./src/layout/index.js",
    "./observability": "./src/observability/index.js",
    "./reports": "./src/reports/index.js",
    "./runtime": "./src/runtime/index.js",
    "./theme": "./src/theme/index.js",
    "./tailwind-preset": "./src/tailwind-preset.js",
    "./hooks/useCurrency.jsx": "./src/hooks/useCurrency.jsx",
    "./hooks/use-mobile.jsx": "./src/hooks/use-mobile.jsx",
    "./hooks/useDistinctValues.js": "./src/hooks/useDistinctValues.js",
    "./lib/gridQuery.js": "./src/lib/gridQuery.js",
    "./lib/validation": "./src/lib/validation/index.js",
    "./styles.css": "./src/styles.css",
    "./components/ui/*": "./src/components/ui/*",
    "./components/import/*": "./src/components/import/*",
    "./lib/*": "./src/lib/*",
    "./pages/*": "./src/pages/*",
    "./components/contract-ui/*": "./src/components/contract-ui/*"
  },
  "files": [
    "src",
    "!src/**/__tests__/**"
  ],
  "scripts": {
    "test": "node --test test/*.test.js src/auth/__tests__/*.test.js src/i18n/__tests__/*.test.js src/runtime/__tests__/*.test.js src/theme/__tests__/*.test.js src/components/ui/__tests__/*.test.js src/lib/__tests__/*.test.js src/lib/validation/__tests__/*.test.js src/lib/import/__tests__/*.test.js",
    "test:vitest": "vitest run",
    "test:consumer": "node scripts/package-consumer-smoke.mjs"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.400.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.0"
  }
}
