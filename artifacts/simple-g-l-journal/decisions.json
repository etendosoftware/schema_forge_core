{
  "$schema": "decisions-v2",
  "window": {
    "category": "finance",
    "name": "Simple G/L Journal",
    "breadcrumb": "Finance / Manual Journals",
    "linesLayout": "inlineEditable",
    "balanceFooter": {
      "debitField": "foreignCurrencyDebit",
      "creditField": "foreignCurrencyCredit"
    }
  },
  "entities": {
    "header": {
      "name": "gLJournal",
      "fields": {
        "documentNo": {
          "visibility": "system",
          "grid": true,
          "reason": "Auto-sequenced document number; read-only to the user (generated by NEO on POST)."
        },
        "description": {
          "visibility": "editable",
          "grid": true,
          "searchable": true
        },
        "documentType": {
          "visibility": "editable",
          "reason": "Document type selector — user picks the journal document type."
        },
        "documentDate": {
          "visibility": "editable",
          "grid": true,
          "defaultExpr": "@#Date@"
        },
        "accountingDate": {
          "visibility": "editable",
          "defaultExpr": "@#Date@"
        },
        "period": {
          "visibility": "editable"
        },
        "currency": {
          "visibility": "editable"
        },
        "opening": {
          "visibility": "editable",
          "reason": "Kept (cheap boolean) per spec — marks an opening-balance journal."
        },
        "multigeneralLedger": {
          "visibility": "editable",
          "reason": "Kept (cheap boolean) per spec — multi-ledger flag."
        },
        "businessPartner": {
          "visibility": "editable"
        },
        "product": {
          "visibility": "editable"
        },
        "project": {
          "visibility": "editable"
        },
        "costCenter": {
          "visibility": "editable"
        },
        "asset": {
          "visibility": "editable"
        },
        "salesCampaign": {
          "visibility": "editable"
        },
        "stDimension": {
          "visibility": "editable"
        },
        "ndDimension": {
          "visibility": "editable"
        },
        "rate": {
          "visibility": "system",
          "reason": "CurrencyRate — derived from currency/period, not user-edited."
        },
        "posted": {
          "visibility": "readOnly",
          "reason": "Posting status — display only. Posting itself is deferred to workstream D."
        },
        "documentAction": {
          "visibility": "discarded",
          "reason": "DocAction button — posting/complete flow deferred to workstream D."
        },
        "accountingSchema": {
          "visibility": "discarded",
          "reason": "Posting-only field; not needed for the simplified manual-journal UI."
        },
        "totalDebitAmount": {
          "visibility": "discarded",
          "reason": "Header debit total — replaced by the live balanceFooter (Σ debit)."
        },
        "totalCreditAmount": {
          "visibility": "discarded",
          "reason": "Header credit total — replaced by the live balanceFooter (Σ credit)."
        },
        "controlAmount": {
          "visibility": "discarded",
          "reason": "Control amount — not used in the simplified UI."
        },
        "currencyRateType": {
          "visibility": "discarded",
          "reason": "Currency rate type — multi-currency rate handling out of scope for V1."
        },
        "gLCategory": {
          "visibility": "discarded",
          "reason": "Posting/accounting classification — not surfaced in the simplified UI."
        },
        "postingType": {
          "visibility": "discarded",
          "reason": "Posting-only dimension — posting deferred to workstream D."
        },
        "documentStatus": {
          "visibility": "discarded",
          "reason": "Document status — completion/posting flow deferred to workstream D."
        }
      }
    },
    "lines": {
      "name": "gLJournalLine",
      "fields": {
        "lineNo": {
          "visibility": "system",
          "grid": true,
          "reason": "Line number — auto-sequenced, not user-edited."
        },
        "gLItems": {
          "visibility": "editable",
          "grid": true,
          "searchable": true,
          "lookup": true,
          "reason": "Account selector (Account_ID) — primary line dimension."
        },
        "accountingCombination": {
          "visibility": "editable",
          "lookup": true,
          "reason": "Accounting combination (C_ValidCombination_ID) selector."
        },
        "description": {
          "visibility": "editable",
          "grid": true,
          "section": "other"
        },
        "foreignCurrencyDebit": {
          "visibility": "editable",
          "grid": true,
          "reason": "Debit amount (AmtSourceDr) — drives the balanceFooter Σ debit."
        },
        "foreignCurrencyCredit": {
          "visibility": "editable",
          "grid": true,
          "reason": "Credit amount (AmtSourceCr) — drives the balanceFooter Σ credit."
        },
        "businessPartner": {
          "visibility": "editable"
        },
        "product": {
          "visibility": "editable"
        },
        "project": {
          "visibility": "editable"
        },
        "activity": {
          "visibility": "editable"
        },
        "salesCampaign": {
          "visibility": "editable"
        },
        "salesRegion": {
          "visibility": "editable"
        },
        "stDimension": {
          "visibility": "editable"
        },
        "ndDimension": {
          "visibility": "editable"
        },
        "asset": {
          "visibility": "editable"
        },
        "costCenter": {
          "visibility": "editable"
        },
        "debit": {
          "visibility": "system",
          "reason": "AmtAcctDr — posting-derived accounted debit, hidden from the user."
        },
        "credit": {
          "visibility": "system",
          "reason": "AmtAcctCr — posting-derived accounted credit, hidden from the user."
        },
        "rate": {
          "visibility": "system",
          "reason": "Line currency rate — derived, not user-edited."
        },
        "openItems": {
          "visibility": "discarded",
          "reason": "Payment integration — dropped for V1 (spec §2)."
        },
        "financialAccount": {
          "visibility": "discarded",
          "reason": "Payment integration (FIN_Financial_Account_ID) — dropped for V1."
        },
        "paymentMethod": {
          "visibility": "discarded",
          "reason": "Payment integration (FIN_Paymentmethod_ID) — dropped for V1."
        },
        "paymentDate": {
          "visibility": "discarded",
          "reason": "Payment integration (Paymentdate) — dropped for V1."
        },
        "relatedPayment": {
          "visibility": "discarded",
          "reason": "Payment integration (FIN_Payment_ID) — dropped for V1."
        },
        "aPRMAddPayment": {
          "visibility": "discarded",
          "reason": "Add Payment button (EM_Aprm_Addpayment) — payment integration dropped for V1."
        },
        "gLItem": {
          "visibility": "discarded",
          "reason": "Financial G/L item (C_Glitem_ID) — tied to payment integration, dropped for V1."
        }
      }
    },
    "accounting": {
      "name": "accounting",
      "exclude": true
    },
    "exchangeRates": {
      "name": "exchangeRates",
      "exclude": true
    }
  },
  "rules": {},
  "discardPatterns": [
    "EM_*"
  ],
  "version": 2
}
