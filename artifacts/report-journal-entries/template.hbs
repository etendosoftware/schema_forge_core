{{!-- Auto-generated grouped listing template for: report-journal-entries --}}
<!DOCTYPE html>
<html><head><meta charset="UTF-8">
<style>
{{{css}}}
.entry-header td { background: #f8fafc; border-top: 2px solid #cbd5e1; border-bottom: none !important; padding: 2mm 3mm; }
.entry-no { font-weight: 700; color: #0f172a; font-size: 9pt; }
.entry-date { font-weight: 700; color: #0f172a; font-size: 9pt; }
.entry-detail { color: #475569; font-size: 8.5pt; }
.entry-line td { border-top: none; border-bottom: 1px solid #f1f5f9 !important; }
.report-totals { display: flex; gap: 8px; margin-top: 8mm; }
.total-card { flex: 1; border: 1px solid #e2e8f0; border-radius: 6px; padding: 4mm 5mm; background: #ffffff; }
.total-label { font-size: 7.5pt; font-weight: 700; color: #64748b; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1.5mm; }
.total-value { font-size: 18pt; font-weight: 700; color: #0f172a; }
</style>
</head>
<body><div class="report-container">
  <div class="report-header">
    <div><div class="report-title">{{meta.title}}</div></div>
    <div class="report-meta"><div>{{formatDate meta.generatedAt}}</div><div>{{meta.recordCount}} records</div></div>
  </div>

  {{#if meta.filters.length}}
  <div class="report-filters"><strong>Filters:</strong>
    {{#each meta.filters}}<span>{{this.label}}: {{this.value}} &nbsp;</span>{{/each}}
  </div>
  {{/if}}

  <table class="report-table">
    <thead><tr>
      <th style="width: 6%">Entry</th>
      <th style="width: 10%">Date</th>
      <th style="width: 20%">Detail</th>
      <th style="width: 9%">Account No.</th>
      <th style="width: 29%">Name</th>
      <th style="width: 13%">Debit</th>
      <th style="width: 13%">Credit</th>
    </tr></thead>
    <tbody>
      {{#each rows}}
        {{#if (isGroupBreak 'fact_acct_group_id' (lookup this 'fact_acct_group_id'))}}
        <tr class="entry-header">
          <td class="entry-no">{{lookup this 'entry_no'}}</td>
          <td class="entry-date">{{formatDate (lookup this 'dateacct')}}</td>
          <td class="entry-detail" colspan="5">{{lookup this 'document_type'}}</td>
        </tr>
        {{/if}}
        <tr class="entry-line">
          <td></td>
          <td></td>
          <td></td>
          <td>{{lookup this 'account_no'}}</td>
          <td>{{lookup this 'account_name'}}</td>
          <td class="cell-amount">{{formatCurrency (lookup this 'amtacctdr')}}</td>
          <td class="cell-amount">{{formatCurrency (lookup this 'amtacctcr')}}</td>
        </tr>
      {{/each}}
    </tbody>
  </table>

  {{#if meta.totals}}
  <div class="report-totals">
    <div class="total-card">
      <div class="total-label">Total Debit</div>
      <div class="total-value">{{formatCurrency meta.totals.amtacctdr}}</div>
    </div>
    <div class="total-card">
      <div class="total-label">Total Credit</div>
      <div class="total-value">{{formatCurrency meta.totals.amtacctcr}}</div>
    </div>
  </div>
  {{/if}}

  <div class="report-footer">
    <div class="report-summary">Total: {{meta.recordCount}} records</div>
    <div>Generated by Etendo Go</div>
  </div>
</div></body></html>
