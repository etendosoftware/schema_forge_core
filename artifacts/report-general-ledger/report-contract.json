{
  "version": 1,
  "reportId": "report-general-ledger",
  "category": "finance",
  "type": "grouped-listing",
  "source": "sql",
  "title": { "en_US": "General Ledger", "es_ES": "Libro Mayor" },
  "orientation": "landscape",
  "sql": {
    "query": "SELECT ev.value, ev.name, fa.dateacct, COALESCE(bp.name, fa.description) AS groupbyname, fa.amtacctdr, fa.amtacctcr, (fa.amtacctdr - fa.amtacctcr) AS total, bp.name AS bpname, p.name AS productname, pj.name AS projectname FROM fact_acct fa JOIN c_elementvalue ev ON ev.c_elementvalue_id = fa.account_id LEFT JOIN c_bpartner bp ON bp.c_bpartner_id = fa.c_bpartner_id LEFT JOIN m_product p ON p.m_product_id = fa.m_product_id LEFT JOIN c_project pj ON pj.c_project_id = fa.c_project_id WHERE fa.ad_client_id IN ('__CLIENT_ID__') AND fa.factaccttype NOT IN ('R', 'C') AND ('__DATEFROM__' = '' OR fa.dateacct >= '__DATEFROM__'::date) AND ('__DATETO__' = '' OR fa.dateacct <= '__DATETO__'::date) AND ('__BPARTNERID__' = '' OR fa.c_bpartner_id = '__BPARTNERID__') AND ('__PRODUCTID__' = '' OR fa.m_product_id = '__PRODUCTID__') AND ('__ORGID__' = '' OR fa.ad_org_id = '__ORGID__') AND ('__ACCTSCHEMAID__' = '' OR fa.c_acctschema_id = '__ACCTSCHEMAID__') AND ('__PROJECTID__' = '' OR fa.c_project_id = '__PROJECTID__') ORDER BY ev.value, ev.name, fa.dateacct"
  },
  "columns": [
    { "field": "dateacct", "label": { "en_US": "Date", "es_ES": "Fecha" }, "type": "date", "width": "10%", "sortable": true },
    { "field": "groupbyname", "label": { "en_US": "Description", "es_ES": "Descripción" }, "type": "string", "width": "25%", "sortable": true },
    { "field": "amtacctdr", "label": { "en_US": "Debit", "es_ES": "Debe" }, "type": "amount", "width": "13%", "sortable": true },
    { "field": "amtacctcr", "label": { "en_US": "Credit", "es_ES": "Haber" }, "type": "amount", "width": "13%", "sortable": true },
    { "field": "total", "label": { "en_US": "Balance", "es_ES": "Saldo" }, "type": "amount", "width": "13%", "sortable": true }
  ],
  "groups": [
    {
      "field": "name",
      "label": { "en_US": "Account", "es_ES": "Cuenta" },
      "headerFields": [
        { "field": "value", "label": { "en_US": "Code", "es_ES": "Código" } }
      ]
    }
  ],
  "parameters": [
    { "name": "dateFrom", "label": { "en_US": "From Date", "es_ES": "Desde" }, "type": "date", "default": "__FIRST_OF_PREV_MONTH__", "required": true, "section": "primary" },
    { "name": "dateTo", "label": { "en_US": "To Date", "es_ES": "Hasta" }, "type": "date", "default": "__TODAY__", "required": true, "section": "primary" },
    { "name": "orgId", "label": { "en_US": "Organization", "es_ES": "Organización" }, "type": "search", "selector": "org", "inputStyle": "modal", "required": true, "autoDefault": true, "section": "primary" },
    { "name": "acctSchemaId", "label": { "en_US": "General Ledger", "es_ES": "Contabilidad" }, "type": "search", "selector": "accounting", "inputStyle": "modal", "required": true, "autoDefault": true, "section": "primary" },
    { "name": "bPartnerId", "label": { "en_US": "Contacts", "es_ES": "Contactos" }, "type": "search", "selector": "bpartner", "multi": true, "inputStyle": "popup", "section": "dimensions", "groupByValue": "bpartner", "groupByField": "bpname" },
    { "name": "productId", "label": { "en_US": "Product", "es_ES": "Producto" }, "type": "search", "selector": "product", "multi": true, "inputStyle": "popup", "section": "dimensions", "groupByValue": "product", "groupByField": "productname" },
    { "name": "projectId", "label": { "en_US": "Project", "es_ES": "Proyecto" }, "type": "search", "selector": "project", "multi": true, "inputStyle": "popup", "section": "dimensions" },
    { "name": "groupBy", "label": { "en_US": "Group results by", "es_ES": "Agrupar por" }, "type": "select", "section": "options" },
    { "name": "showOpenBalances", "label": { "en_US": "Include open balances", "es_ES": "Incluir saldos iniciales" }, "type": "boolean", "description": "Keep open items visible in the generated report.", "section": "options" }
  ],
  "defaultSort": { "field": "dateacct", "direction": "asc" },
  "outputs": ["pdf", "xlsx", "csv", "html"],
  "summary": { "totalRows": true },
  "mockDataFile": "mock-data.json"
}
