  "rules": {
    "ReadOnly_When_Processed": {
      "type": "displayLogic",
      "entity": "customerReturn",
      "decision": "Keep",
      "description": "Lock all editable fields when return document status is Completed or Voided"
    },
    "BP_AutoFill_Address": {
      "type": "callout",
      "entity": "customerReturn",
      "decision": "Keep",
      "description": "When changing business partner, auto-fill partner address and payment terms"
    },
    "ShipmentLine_AutoFill_Product": {
      "type": "callout",
      "entity": "customerReturnLine",
      "decision": "Keep",
      "description": "When selecting a shipment line, auto-fill product, quantity, price, tax and UOM from the original shipment line"
    },
    "Line_Recalc_Header_Total": {
      "type": "eventHandler",
      "entity": "customerReturnLine",
      "decision": "Keep",
      "description": "After saving a return line, recalculate header totals (TotalLines, GrandTotal)"
    },
    "Qty_Validate_NotExceedShipment": {
      "type": "eventHandler",
      "entity": "customerReturnLine",
      "decision": "Keep",
      "description": "Validate that return quantity does not exceed the original shipment quantity minus already-returned quantities"
    },
    "DocAction_Process": {
      "type": "obuiapp_process",
      "entity": "customerReturn",
      "decision": "Keep",
      "description": "Complete/void the return document. On completion generates a return receipt (goods come back to warehouse) and optionally a customer credit memo"
    }
  },
