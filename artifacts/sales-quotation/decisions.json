{
  "$schema": "decisions-v2",
  "window": {
    "category": "sales",
    "name": "Sales Quotation",
    "salesTheme": true,
    "notesField": "description",
    "relatedDocuments": true,
    "hideDeleteWhenComplete": true,
    "hidePrint": true,
    "customComponents": {
      "topbarRight": "QuotationTopbarActions"
    },
    "labelOverrides": {
      "es_ES": {
        "C_BPartner_ID": "Contacto"
      },
      "en_US": {
        "C_BPartner_ID": "Contact"
      }
    },
    "menuActions": [
      {
        "key": "reject",
        "label": "Reject",
        "labelKey": "rejectQuotation",
        "destructive": true,
        "visibleWhenStatus": ["UE"]
      }
    ],
    "processOverrides": {
      "Complete": {
        "exclude": true
      },
      "Convert to Order": {
        "exclude": true
      },
      "Void": {
        "label": "Void",
        "style": "destructive",
        "displayLogicRaw": "@documentStatus@='CO'"
      },
      "Reactivate": {
        "label": "Reactivate",
        "displayLogicRaw": "@documentStatus@='VO'"
      }
    },
    "noHeaderBorder": true,
    "dateFilterKey": "orderDate",
    "hideSaveStatuses": ["CA", "ETGO_CI", "CL", "VO", "CJ"]
  },
  "entities": {
    "header": {
      "name": "quotation",
      "draftMode": {
        "enabled": true,
        "processField": "documentAction",
        "processValue": "CO",
        "label": "soConfirmBtn",
        "completedStatuses": ["CA", "ETGO_CI", "CL", "VO", "CJ"]
      },
      "fields": {
        "documentNo": {
          "visibility": "readOnly",
          "grid": true,
          "gridOrder": 2,
          "searchable": true,
          "inputMode": "text",
          "section": "principal",
          "seq": 2
        },
        "businessPartner": {
          "grid": true,
          "gridOrder": 3,
          "searchable": true,
          "reference": "BusinessPartner",
          "inputMode": "search",
          "displayLogic": null,
          "section": "principal",
          "seq": 1,
          "selectorFilter": "isCustomer=Y"
        },
        "partnerAddress": {
          "reference": "BusinessPartnerLocation",
          "inputMode": "dependent",
          "dependsOn": {
            "field": "businessPartner",
            "filterKey": "C_BPartner_ID"
          },
          "section": "principal"
        },
        "orderDate": {
          "grid": true,
          "gridOrder": 1,
          "searchable": true,
          "inputMode": "date",
          "section": "principal",
          "seq": 3
        },
        "validUntil": {
          "grid": true,
          "gridOrder": 5,
          "searchable": true,
          "inputMode": "date",
          "section": "principal",
          "readOnlyLogic": "@Processed@='Y'"
        },
        "scheduledDeliveryDate": {
          "visibility": "discarded"
        },
        "priceList": {
          "section": "principal"
        },
        "currency": {
          "visibility": "readOnly",
          "grid": false,
          "form": false,
          "section": "summary"
        },
        "paymentTerms": {
          "section": "principal"
        },
        "paymentMethod": {
          "section": "principal"
        },
        "salesRepresentative": {
          "visibility": "system"
        },
        "orderReference": {
          "visibility": "discarded"
        },
        "rejectReason": {
          "visibility": "editable",
          "form": false,
          "grid": false,
          "readOnlyLogic": "@DocStatus@='CJ'|@DocStatus@='CA'"
        },
        "summedLineAmount": {
          "visibility": "readOnly",
          "section": "summary"
        },
        "grandTotalAmount": {
          "visibility": "readOnly",
          "grid": true,
          "gridOrder": 6,
          "section": "summary"
        },
        "documentStatus": {
          "visibility": "readOnly",
          "grid": true,
          "gridOrder": 4,
          "searchable": true,
          "form": false
        },
        "invoiceAddress": {
          "visibility": "discarded"
        },
        "description": {
          "inputMode": "textarea",
          "section": "collapsed",
          "readOnlyLogic": "@Processed@='Y'"
        },
        "client": {
          "visibility": "system"
        },
        "organization": {
          "visibility": "system"
        },
        "transactionDocument": {
          "visibility": "system"
        },
        "documentType": {
          "visibility": "system"
        },
        "salesTransaction": {
          "visibility": "system"
        },
        "created": {
          "visibility": "system"
        },
        "updated": {
          "visibility": "system"
        },
        "active": {
          "visibility": "discarded"
        },
        "accountingDate": {
          "visibility": "discarded"
        },
        "invoiceTerms": {
          "visibility": "discarded"
        },
        "deliveryTerms": {
          "visibility": "discarded"
        },
        "deliveryMethod": {
          "visibility": "discarded"
        },
        "priority": {
          "visibility": "discarded"
        },
        "formOfPayment": {
          "visibility": "discarded"
        },
        "project": {
          "visibility": "discarded"
        },
        "processed": {
          "visibility": "readOnly",
          "form": false,
          "grid": false
        },
        "posted": {
          "visibility": "discarded"
        },
        "warehouse": {
          "visibility": "discarded"
        },
        "costcenter": {
          "visibility": "discarded"
        },
        "stDimension": {
          "visibility": "discarded"
        },
        "ndDimension": {
          "visibility": "discarded"
        },
        "freightCostRule": {
          "visibility": "discarded"
        },
        "freightAmount": {
          "visibility": "discarded"
        },
        "chargeAmount": {
          "visibility": "discarded"
        },
        "printDescription": {
          "visibility": "discarded"
        },
        "deliveryLocation": {
          "visibility": "discarded"
        },
        "isSotrx": {
          "visibility": "discarded"
        },
        "documentAction": {
          "visibility": "system"
        },
        "createOrder": {
          "visibility": "system"
        },
        "cashVAT": {
          "visibility": "discarded"
        }
      },
      "javaQualifier": "salesQuotationHeaderHandler"
    },
    "lines": {
      "javaQualifier": "orderLineHandler",
      "name": "quotationLine",
      "fields": {
        "lineNo": {
          "visibility": "system"
        },
        "product": {
          "grid": true,
          "searchable": true,
          "inputMode": "search",
          "lookup": true,
          "order": 1,
          "gridOrder": 1,
          "forceCalloutFields": ["unitPrice", "tax", "uOM", "grossUnitPrice", "discount"]
        },
        "orderedQuantity": {
          "grid": true,
          "inputMode": "number",
          "order": 3,
          "gridOrder": 3
        },
        "uOM": {
          "visibility": "system"
        },
        "unitPrice": {
          "grid": true,
          "form": true,
          "inputMode": "number",
          "order": 4,
          "gridOrder": 4
        },
        "discount": {
          "grid": true,
          "inputMode": "number",
          "order": 5,
          "gridOrder": 5
        },
        "lineNetAmount": {
          "grid": false,
          "form": false
        },
        "tax": {
          "grid": true,
          "form": true,
          "inputMode": "selector",
          "order": 6,
          "gridOrder": 6,
          "forceCalloutFields": ["lineGrossAmount", "grossUnitPrice", "lineNetAmount"]
        },
        "description": {
          "grid": true,
          "form": true,
          "inputMode": "textarea",
          "order": 2,
          "gridOrder": 2
        },
        "client": {
          "visibility": "system"
        },
        "organization": {
          "visibility": "system"
        },
        "salesOrder": {
          "visibility": "system"
        },
        "orderDate": {
          "visibility": "system"
        },
        "scheduledDeliveryDate": {
          "visibility": "system"
        },
        "currency": {
          "visibility": "system"
        },
        "businessPartner": {
          "visibility": "system"
        },
        "operativeUOM": {
          "visibility": "discarded"
        },
        "attributeSetValue": {
          "visibility": "discarded"
        },
        "orderLine": {
          "visibility": "discarded"
        },
        "project": {
          "visibility": "discarded"
        },
        "costcenter": {
          "visibility": "discarded"
        },
        "stDimension": {
          "visibility": "discarded"
        },
        "ndDimension": {
          "visibility": "discarded"
        },
        "printDescription": {
          "visibility": "discarded"
        },
        "descriptionOnly": {
          "visibility": "discarded"
        },
        "explode": {
          "visibility": "discarded"
        },
        "cancelDiscountsAndPromotions": {
          "visibility": "discarded"
        },
        "baseNetUnitPrice": {
          "visibility": "discarded"
        },
        "lineGrossAmount": {
          "grid": true,
          "form": true,
          "section": "principal",
          "order": 7,
          "gridOrder": 7
        },
        "editLineNetAmount": {
          "visibility": "discarded"
        },
        "resourceAssignment": {
          "visibility": "discarded"
        },
        "priceLimit": {
          "visibility": "discarded"
        },
        "operativeQuantity": {
          "visibility": "discarded"
        },
        "grossUnitPrice": {
          "visibility": "discarded"
        },
        "listPrice": {
          "visibility": "discarded"
        },
        "grossListPrice": {
          "visibility": "discarded"
        },
        "taxableAmount": {
          "visibility": "discarded"
        }
      }
    },
    "lineTax": {
      "exclude": true
    },
    "mReservationStock": {
      "exclude": true
    },
    "basicDiscounts": {
      "exclude": true
    },
    "tax": {
      "exclude": true
    },
    "finPaymentSchedOrdV": {
      "exclude": true
    },
    "finPaymentDetailV": {
      "exclude": true
    }
  },
  "rules": {
    "BP_AutoFill_Address": {
      "type": "callout",
      "entity": "quotation",
      "decision": "Keep",
      "description": "When changing business partner, auto-fill delivery address and price list"
    },
    "Line_Recalc_Totals": {
      "type": "eventHandler",
      "entity": "quotationLine",
      "decision": "Keep",
      "description": "After saving a line, recalculate header totals (TotalLines, GrandTotal)"
    },
    "Product_AutoFill_Price": {
      "type": "callout",
      "entity": "quotationLine",
      "decision": "Keep",
      "description": "When selecting a product, auto-fill unit price, tax and UOM from price list"
    },
    "Line_Calc_NetAmount": {
      "type": "callout",
      "entity": "quotationLine",
      "decision": "Keep",
      "description": "Recalculate line net amount when quantity, price or discount changes"
    },
    "ReadOnly_When_Processed": {
      "type": "displayLogic",
      "entity": "quotation",
      "decision": "Keep",
      "description": "Lock all editable fields when quotation status is Completed or Voided"
    },
    "ValidUntil_Default": {
      "type": "callout",
      "entity": "quotation",
      "decision": "Keep",
      "description": "Default validUntil to orderDate + 30 days when creating a new quotation"
    },
    "Convert_To_Order": {
      "type": "process",
      "entity": "quotation",
      "decision": "Keep",
      "description": "Process to convert an approved quotation into a Sales Order (copies header + lines, sets new doc type)"
    },
    "Delivery_Fields_Hidden": {
      "type": "displayLogic",
      "entity": "quotation",
      "decision": "Omit",
      "description": "Delivery-related fields (isDelivered, deliveryLocation, warehouse on header) are not relevant for quotations and are omitted from the schema"
    }
  },
  "discardPatterns": [],
  "version": 2
}
