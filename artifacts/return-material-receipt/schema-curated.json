{
  "version": "0.1.0",
  "window": {
    "id": "53013",
    "name": "Return Material Receipt",
    "primaryEntity": "returnReceipt",
    "category": "sales",
    "whereClause": "M_InOut.IsSOTrx='Y' AND M_InOut.MovementType='C+'",
    "notes": "Physical receipt of goods returned by a customer. Uses M_InOut with MovementType='C+' (customer inbound return). Typically linked to a Return from Customer (M_RMA) authorization. The sales-side counterpart of Return to Vendor Shipment (V-)."
  },
  "entities": [
    {
      "name": "returnReceipt",
      "tableName": "M_InOut",
      "fields": [
        { "name": "businessPartner", "column": "C_BPartner_ID", "type": "foreignKey", "reference": "BusinessPartner", "inputMode": "search", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": true, "notes": "Customer returning goods. Filter BP where IsCustomer='Y'" },
        { "name": "partnerAddress", "column": "C_BPartner_Location_ID", "type": "foreignKey", "reference": "BusinessPartnerLocation", "inputMode": "dependent", "dependsOn": { "field": "businessPartner", "filterKey": "businessPartnerId" }, "visibility": "editable", "required": true, "grid": false, "form": true, "searchable": false },
        { "name": "movementDate", "column": "MovementDate", "type": "date", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "dateAcct", "column": "DateAcct", "type": "date", "visibility": "editable", "required": true, "grid": false, "form": true, "searchable": false },
        { "name": "warehouse", "column": "M_Warehouse_ID", "type": "foreignKey", "reference": "Warehouse", "inputMode": "selector", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "returnReason", "column": "M_RMA_ID", "type": "foreignKey", "reference": "ReturnMaterialAuthorization", "inputMode": "search", "visibility": "editable", "required": false, "grid": true, "form": true, "searchable": true, "notes": "Link to Return from Customer (RMA) authorization. Optional but typical workflow requires an approved RMA before receiving returned goods." },
        { "name": "orderReference", "column": "C_Order_ID", "type": "foreignKey", "reference": "SalesOrder", "inputMode": "search", "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": true, "notes": "Original sales order reference. May be auto-filled from RMA." },
        { "name": "description", "column": "Description", "type": "string", "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": false },
        { "name": "poReference", "column": "POReference", "type": "string", "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": true },
        { "name": "isActive", "column": "IsActive", "type": "boolean", "visibility": "editable", "required": true, "grid": false, "form": true, "searchable": false },

        { "name": "documentNo", "column": "DocumentNo", "type": "string", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "docStatus", "column": "DocStatus", "type": "string", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true },

        { "name": "adClientId", "column": "AD_Client_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.client" } },
        { "name": "adOrgId", "column": "AD_Org_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.organization" } },
        { "name": "isSotrx", "column": "IsSOTrx", "type": "boolean", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "true" }, "notes": "Always 'Y' — this is a sales-side (customer) transaction" },
        { "name": "movementType", "column": "MovementType", "type": "string", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "'C+'" }, "notes": "C+ = Customer Return (inbound from customer). Goods Shipment uses C- (outbound to customer)." },
        { "name": "cDocTypeId", "column": "C_DocType_ID", "type": "foreignKey", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "doctype.returnMaterialReceipt" } },
        { "name": "processed", "column": "Processed", "type": "boolean", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "docStatus === 'CO' ? true : false" } },
        { "name": "created", "column": "Created", "type": "datetime", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "now()" } },
        { "name": "updated", "column": "Updated", "type": "datetime", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "now()" } }
      ]
    },
    {
      "name": "returnReceiptLine",
      "tableName": "M_InOutLine",
      "fields": [
        { "name": "product", "column": "M_Product_ID", "type": "foreignKey", "reference": "Product", "inputMode": "search", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "movementQty", "column": "MovementQty", "type": "number", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": false, "notes": "Quantity being received back. Positive value — the MovementType C+ handles the direction." },
        { "name": "locator", "column": "M_Locator_ID", "type": "foreignKey", "reference": "Locator", "inputMode": "selector", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": false, "notes": "Destination storage bin where returned goods will be placed" },
        { "name": "lineNo", "column": "Line", "type": "integer", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": false },
        { "name": "description", "column": "Description", "type": "string", "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": false },
        { "name": "returnOrderLine", "column": "C_OrderLine_ID", "type": "foreignKey", "reference": "SalesOrderLine", "inputMode": "dependent", "dependsOn": { "field": "returnReceipt.orderReference", "filterKey": "cOrderId" }, "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": false, "notes": "Link to original sales order line. Enables traceability of which SO line this return corresponds to." },
        { "name": "rmaLine", "column": "M_RMALine_ID", "type": "foreignKey", "reference": "ReturnMaterialAuthorizationLine", "inputMode": "dependent", "dependsOn": { "field": "returnReceipt.returnReason", "filterKey": "mRmaId" }, "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": false, "notes": "Link to RMA line. When created from RMA, this is auto-filled." },

        { "name": "uom", "column": "C_UOM_ID", "type": "foreignKey", "reference": "UOM", "inputMode": "selector", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false },

        { "name": "adClientId", "column": "AD_Client_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.client" } },
        { "name": "adOrgId", "column": "AD_Org_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.organization" } },
        { "name": "mInoutId", "column": "M_InOut_ID", "type": "foreignKey", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromParent", "source": "returnReceipt.id" } },
        { "name": "movementDate", "column": "MovementDate", "type": "date", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromParent", "source": "returnReceipt.movementDate" } },
        { "name": "cBpartnerId", "column": "C_BPartner_ID", "type": "foreignKey", "visibility": "system", "required": false, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromParent", "source": "returnReceipt.businessPartner" } },
        { "name": "warehouse", "column": "M_Warehouse_ID", "type": "foreignKey", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromParent", "source": "returnReceipt.warehouse" } }
      ]
    }
  ]
}
