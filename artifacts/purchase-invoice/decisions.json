  "rules": {
    "SE_Invoice_BPartner": {
      "entity": "invoice",
      "decision": "Omit",
      "description": "Auto-fill partner address, payment terms, price list from business partner. Classic UI only.",
      "impactIfOmitted": "Users must manually set address, payment terms, and price list after choosing a business partner."
    },
    "SE_Invoice_BPartnerLocation": {
      "entity": "invoice",
      "decision": "Omit",
      "description": "Cascade on partner address change. Classic UI only.",
      "impactIfOmitted": "No cascade on address change."
    },
    "SL_Invoice_DocType": {
      "entity": "invoice",
      "decision": "Omit",
      "description": "Auto-fill payment terms and method from document type. Classic UI only.",
      "impactIfOmitted": "Users must manually set payment terms and method."
    },
    "SE_Invoice_AccountingDate": {
      "entity": "invoice",
      "decision": "Omit",
      "description": "Auto-fill accounting date. Backend default applies on save.",
      "impactIfOmitted": "Backend sets accounting date on save."
    },
    "SL_Invoice_PriceList": {
      "entity": "invoice",
      "decision": "Omit",
      "description": "Cascade on price list change. Classic UI only.",
      "impactIfOmitted": "No cascade on price list change."
    },
    "SL_Invoice_Product": {
      "entity": "invoiceLine",
      "decision": "Omit",
      "description": "Auto-fill price, UOM, tax from product selection. Classic UI only.",
      "impactIfOmitted": "Users must manually set price, UOM, and tax after selecting a product."
    },
    "SL_Invoice_Amt": {
      "entity": "invoiceLine",
      "decision": "Omit",
      "description": "Recalculate line amount on quantity/price change. Backend handles on save.",
      "impactIfOmitted": "Line amounts calculated by backend on save."
    },
    "SL_Invoice_Conversion": {
      "entity": "invoiceLine",
      "decision": "Omit",
      "description": "UOM conversion calculation. Backend handles on save.",
      "impactIfOmitted": "UOM conversion calculated by backend."
    },
    "OperativeQuantity_To_BaseQuantity": {
      "entity": "invoiceLine",
      "decision": "Omit",
      "description": "Converts operative quantity to base quantity. Backend handles on save.",
      "impactIfOmitted": "Base quantity calculated by backend."
    },
    "VAL_BPartnerLocation_BillTo": {
      "type": "validation",
      "entity": "invoice",
      "decision": "Keep",
      "description": "Filters partner address selector to bill-to locations of the selected business partner.",
      "impactIfOmitted": "Users could select irrelevant addresses."
    },
    "VAL_DocType_APInvoice": {
      "type": "validation",
      "entity": "invoice",
      "decision": "Keep",
      "description": "Filters document type to AP invoices and credit memos (IsSOTrx=N).",
      "impactIfOmitted": "Users could select wrong document types."
    },
    "VAL_User_BPartnerContact": {
      "type": "validation",
      "entity": "invoice",
      "decision": "Keep",
