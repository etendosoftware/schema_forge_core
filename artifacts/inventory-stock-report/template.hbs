{{!-- Inventory Stock Report (Neo source) --}}
<!DOCTYPE html>
<html><head><meta charset="UTF-8">
<style>
{{{css}}}
.group-header td { border: none !important; }
</style>
</head>
<body><div class="report-container">
  <div class="report-header">
    <div><div class="report-title">{{meta.title}}</div></div>
    <div class="report-meta"><div>{{formatDate meta.generatedAt}}</div><div>{{meta.recordCount}} records</div></div>
  </div>

  {{#if meta.filters.length}}
  <div class="report-filters"><strong>Filters:</strong>
    {{#each meta.filters}}<span>{{this.label}}: {{this.value}} &nbsp;</span>{{/each}}
  </div>
  {{/if}}

  <table class="report-table">
    <thead><tr>
      <th style="width: 15%">Search Key</th>
      <th style="width: 30%">Product</th>
      <th style="width: 10%">UoM</th>
      <th style="width: 15%">Qty on Hand</th>
      <th style="width: 12%">Unit Cost</th>
      <th style="width: 18%">Total Valuation</th>
    </tr></thead>
    <tbody>
      {{#each rows}}
        {{#if (isGroupBreak 'warehouse' (lookup this 'warehouse'))}}
        <tr class="group-header">
          <td colspan="6" style="background: #000000; color: #ffffff; font-weight: 600; padding: 2mm 4mm; font-size: 11pt;">
            Warehouse: {{lookup this 'warehouse'}}
          </td>
        </tr>
        {{/if}}
        <tr>
          <td>{{lookup this 'productSearchKey'}}</td>
          <td>{{lookup this 'product'}}</td>
          <td>{{lookup this 'uom'}}</td>
          <td class="cell-amount">{{formatCurrency (lookup this 'qtyOnHand')}}</td>
          <td class="cell-amount">{{formatCurrency (lookup this 'unitCost')}}</td>
          <td class="cell-amount">{{formatCurrency (lookup this 'totalValuation')}}</td>
        </tr>
      {{/each}}
    </tbody>
  </table>

  <div class="report-footer">
    <div class="report-summary">Total: {{meta.recordCount}} records</div>
    <div>Generated by Etendo Go</div>
  </div>
</div></body></html>
