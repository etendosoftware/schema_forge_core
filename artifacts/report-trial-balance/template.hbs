{{!-- Trial Balance report template --}}
<!DOCTYPE html>
<html><head><meta charset="UTF-8">
<style>
{{{css}}}
.account-link { cursor: pointer; color: #2563eb; text-decoration: underline; font-weight: 600; }
.account-link:hover { opacity: 0.75; text-decoration: none; }
tfoot tr td { font-weight: bold; border-top: 2px solid #333; }
</style>
</head>
<body><div class="report-container">
  <div class="report-header">
    <div><div class="report-title">{{meta.title}}</div></div>
    <div class="report-meta"><div>{{formatDate meta.generatedAt}}</div><div>{{meta.recordCount}} records</div></div>
  </div>

  {{#if meta.filters.length}}
  <div class="report-filters"><strong>Filters:</strong>
    {{#each meta.filters}}<span>{{this.label}}: {{this.value}} &nbsp;</span>{{/each}}
  </div>
  {{/if}}

  <table class="report-table">
    <thead>
      <tr>
        <th colspan="2"></th>
        <th style="text-align:center; border-bottom: 1px solid #e2e8f0;">Balance As Of {{meta.params.dateFrom}}</th>
        <th colspan="2" style="text-align:center; border-bottom: 1px solid #e2e8f0;">Activity</th>
        <th style="text-align:center; border-bottom: 1px solid #e2e8f0;">Balance As Of {{meta.params.dateTo}}</th>
      </tr>
      <tr>
        <th style="width:10%">Account No.</th>
        <th style="width:30%">Name</th>
        <th style="width:15%" class="cell-amount">Opening Balance</th>
        <th style="width:12%" class="cell-amount">Debit</th>
        <th style="width:12%" class="cell-amount">Credit</th>
        <th style="width:15%" class="cell-amount">Closing Balance</th>
      </tr>
    </thead>
    <tbody>
      {{#each rows}}
      <tr>
        <td><span class="account-link" onclick="window.parent.postMessage({type:'trial-balance-drilldown',accountId:'{{lookup this 'account_id'}}',accountValue:'{{lookup this 'account_no'}}',accountName:'{{lookup this 'account_name'}}'},'*')">{{lookup this 'account_no'}}</span></td>
        <td>{{lookup this 'account_name'}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'opening_balance')}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'activity_debit')}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'activity_credit')}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'closing_balance')}}</td>
      </tr>
      {{/each}}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="2">Totals</td>
        <td class="cell-amount"></td>
        <td class="cell-amount">{{formatCurrency (sumField rows 'activity_debit')}}</td>
        <td class="cell-amount">{{formatCurrency (sumField rows 'activity_credit')}}</td>
        <td class="cell-amount"></td>
      </tr>
    </tfoot>
  </table>

  <div class="report-footer">
    <div class="report-summary">Total: {{meta.recordCount}} records</div>
    <div>Generated by Etendo Go</div>
  </div>
</div></body></html>
