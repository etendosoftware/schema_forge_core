      "id": "B3DF10D5093140319BB2FBD43E5D8C47",
      "name": "FIN_Payment Status validation",
      "column": "Status",
      "code": "(((@Isreceipt@='Y') AND Value not IN  ('PPM','PWNC')) OR ((@Isreceipt@='N') AND Value not IN ('RPR','RDNC')))",
      "isSimple": true
    },
    {
      "type": "validation",
      "source": "AD_Val_Rule",
      "id": "FF80808130B107670130B118E5F60020",
      "name": "FIN_PaymentMethodsWithAccountIsReceiptControl",
      "column": "Fin_Paymentmethod_ID",
      "code": "EXISTS (SELECT 1 FROM FIN_FinAcc_PaymentMethod fapm WHERE FIN_PaymentMethod.FIN_PaymentMethod_ID=fapm.FIN_PaymentMethod_ID\nAND fapm.isActive='Y'\nAND fapm.Payin_Allow = (SELECT CASE WHEN '@FIN_ISRECEIPT@'='Y' THEN 'Y' ELSE fapm.Payin_Allow END FROM DUAL)\nAND fapm.Payout_Allow = (SELECT CASE WHEN '@FIN_ISRECEIPT@'='N' THEN 'Y' ELSE fapm.Payout_Allow END FROM DUAL))",
      "isSimple": false
    },
