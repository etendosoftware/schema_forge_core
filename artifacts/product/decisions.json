{
  "$schema": "decisions-v2",
  "window": {
    "category": "inventory",
    "name": "Product",
    "breadcrumb": "Inventory / Product",
    "layoutType": "gallery",
    "sidebarLayout": true,
    "hidePrint": true,
    "hideMoreMenu": true,
    "hideLink": true,
    "contentBg": "bg-white",
    "listbarPaddingX": "px-2",
    "tablePaddingX": "px-2",
    "formCardPadding": "px-2 pb-2",
    "compactSidebarPadding": true,
    "tabsBarPaddingX": "px-2",
    "primaryTabsVariant": "pill",
    "toolbarPaddingX": "px-2",
    "toolbarBorderBottom": true,
    "autoSaveOnBlur": true,
    "noHeaderBorder": true,
    "whiteFormBackground": true,
    "sidebarClassName": "w-[30%] shrink-0 overflow-y-auto pt-2 pl-0 pr-4 pb-5 border-l border-[#E8EAEF]",
    "attachments": true,
    "customTabsAfterBottom": true,
    "detailEntity": null,
    "customPanelTabs": [
      { "key": "pricing", "labelKey": "price", "component": "ProductPriceBar" }
    ],
    "labelOverrides": {
      "en_US": {
        "M_Product_Category_ID": "Category",
        "ProductType": "Type"
      },
      "es_ES": {
        "M_Product_Category_ID": "Categoría",
        "ProductType": "Tipo"
      }
    },
    "headerExtra": {},
    "primaryTabs": [
      { "key": "general", "label": "General" },
      { "key": "additionalInfo", "label": "Additional Info", "panel": "ProductAdditionalInfoPanel" }
    ],
    "secondaryTabs": {}
  },
  "entities": {
    "intrastat": { "exclude": true },
    "product": {
      "fields": {
        "searchKey": {
          "grid": true,
          "searchable": true,
          "section": "principal",
          "seq": 1
        },
        "name": {
          "grid": true,
          "searchable": true,
          "section": "principal",
          "seq": 2
        },
        "description": {
          "type": "textarea",
          "section": "principal",
          "seq": 3
        },
        "productType": {
          "grid": true,
          "searchable": true,
          "reference": "ProductType",
          "inputMode": "selector",
          "section": "principal",
          "displayLogic": null,
          "seq": 5,
          "enumVariants": {
            "I": "blue",
            "S": "purple",
            "R": "teal",
            "E": "orange"
          }
        },
        "productCategory": {
          "grid": true,
          "searchable": true,
          "reference": "ProductCategory",
          "section": "principal",
          "seq": 6
        },
        "uOM": {
          "grid": true,
          "section": "principal",
          "seq": 7
        },
        "image": {
