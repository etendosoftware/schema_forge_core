{
  "version": 1,
  "reportId": "tax-report",
  "category": "finance",
  "type": "listing",
  "source": "neo",
  "title": { "en_US": "Tax Report", "es_ES": "Informe de Impuestos" },
  "orientation": "landscape",
  "neo": {
    "endpoint": "/sws/neo/tax-report",
    "method": "POST",
    "body": {},
    "dataPath": "response.data",
    "handler": "taxReportHandler"
  },
  "columns": [
    { "field": "taxName",    "label": { "en_US": "Tax Name",    "es_ES": "Impuesto"          }, "type": "string", "width": "22%" },
    { "field": "rate",       "label": { "en_US": "Rate %",      "es_ES": "% Impuesto"         }, "type": "number", "width": "8%"  },
    { "field": "taxBaseAmt", "label": { "en_US": "Tax Base",    "es_ES": "Base Imponible"     }, "type": "amount", "width": "15%" },
    { "field": "taxAmt",     "label": { "en_US": "Tax Amount",  "es_ES": "Importe Impuesto"   }, "type": "amount", "width": "15%" },
    { "field": "totalAmt",   "label": { "en_US": "Total",       "es_ES": "Importe Total"      }, "type": "amount", "width": "15%" }
  ],
  "groups": [],
  "filters": [],
  "parameters": [
    { "name": "orgId",           "label": { "en_US": "Organization",       "es_ES": "Organización"        }, "type": "search",  "selector": "org",       "inputStyle": "popup-single", "required": true,  "hidden": true, "autoDefault": true },
    { "name": "dateType",        "label": { "en_US": "Date Type",          "es_ES": "Tipo de Fecha"       }, "type": "select",  "options": [
      { "value": "acct",      "label": { "en_US": "Accounting Date", "es_ES": "Fecha Contable"      } },
      { "value": "operation", "label": { "en_US": "Operation Date",  "es_ES": "Fecha de Operación"  } }
    ], "default": "acct", "section": "primary" },
    { "name": "dateFrom",        "label": { "en_US": "From Date",          "es_ES": "Desde Fecha"         }, "type": "date",    "required": true,  "default": "__FIRST_OF_YEAR__", "section": "primary" },
    { "name": "dateTo",          "label": { "en_US": "To Date",            "es_ES": "Hasta Fecha"         }, "type": "date",    "required": true,  "default": "__TODAY__",         "section": "primary" },
    { "name": "currencyId",      "label": { "en_US": "Currency",           "es_ES": "Moneda"              }, "type": "search",  "selector": "currency",  "inputStyle": "popup-single", "required": true, "autoDefault": true, "section": "primary" },
    { "name": "bPartnerId",      "label": { "en_US": "Contacts",           "es_ES": "Contactos"           }, "type": "search",  "selector": "bpartner",  "inputStyle": "popup",        "section": "primary" },
    { "name": "bpNameType",      "label": { "en_US": "Contact Name", "es_ES": "Nombre de Contacto" }, "type": "select",  "options": [
      { "value": "commercial", "label": { "en_US": "Commercial", "es_ES": "Comercial" } },
      { "value": "legal",      "label": { "en_US": "Legal",      "es_ES": "Legal"     } }
    ], "default": "commercial", "section": "primary" },
    { "name": "transactionType", "label": { "en_US": "Transaction Type",   "es_ES": "Tipo de Transacción" }, "type": "select",  "options": [
      { "value": "S", "label": { "en_US": "Sales / Receipts",       "es_ES": "Ventas / Cobros"    } },
      { "value": "P", "label": { "en_US": "Purchases / Payments",   "es_ES": "Compras / Pagos"    } },
      { "value": "B", "label": { "en_US": "Both",                   "es_ES": "Ambos"               } }
    ], "default": "B", "section": "primary" },
    { "name": "taxType",         "label": { "en_US": "Tax Type",           "es_ES": "Tipo Impuesto"       }, "type": "select",  "options": [
      { "value": "tax",         "label": { "en_US": "Tax",         "es_ES": "Impuesto"  } },
      { "value": "withholding", "label": { "en_US": "Withholding", "es_ES": "Retención" } }
    ], "default": "tax", "section": "options" },
    { "name": "taxId",           "label": { "en_US": "Tax Rate",           "es_ES": "Impuesto / Retención" }, "type": "search", "selector": "tax", "inputStyle": "popup-single", "section": "options" },
    { "name": "showDetails",     "label": { "en_US": "Show Details",       "es_ES": "Mostrar Detalle"     }, "type": "boolean", "section": "options" },
    { "name": "groupByBp",       "label": { "en_US": "Group by Contact", "es_ES": "Agrupar por Contacto" }, "type": "boolean", "section": "options" }
  ],
  "defaultSort": { "field": "taxName", "direction": "asc" },
  "outputs": ["pdf", "xlsx", "csv", "html"],
  "summary": { "totalRows": true },
  "mockDataFile": "mock-data.json"
}
