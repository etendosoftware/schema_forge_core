{{!-- Tax Report --}}
<!DOCTYPE html>
<html><head><meta charset="UTF-8"><style>
{{{css}}}
.report-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 40px; margin: 8px 0 16px; font-size: 12px; }
.report-info-grid span { color: #555; }
.report-info-grid strong { color: #111; }

/* Section banners (Purchases / Sales) */
.section-banner { font-size: 15px; font-weight: bold; color: #fff; background: #1e3a5f; padding: 6px 12px; margin: 20px 0 0; }

/* Tax group header */
.tax-group-header td { font-weight: bold; font-size: 13px; background: #dde6f0; padding: 6px 8px; border-top: 2px solid #1e3a5f; border-bottom: 1px solid #aac; }
.tax-group-total td { font-weight: bold; background: #f5f7fa; border-top: 1px solid #aaa; border-bottom: 2px solid #333; }

/* BP sub-group */
.bp-header-row td { font-weight: 600; font-size: 12px; padding-top: 8px; padding-bottom: 2px; border: none; background: transparent; color: #333; }
.bp-total-row td { font-style: italic; color: #555; border-top: 1px dashed #ccc; font-size: 11px; }

/* Document rows */
.doc-row td { border: none; font-size: 11px; }
.doc-link { cursor: pointer; color: #2563eb; text-decoration: underline; }
.doc-link:hover { opacity: 0.75; text-decoration: none; }

/* Category / Rate summary */
.cat-header td, .rate-header td { font-weight: bold; font-size: 13px; background: #f0f4fa; padding: 6px 8px; border-top: 2px solid #1e3a5f; border-bottom: 1px solid #aac; }
.cat-row td, .rate-row td { font-size: 12px; }
.cat-total td, .rate-total td { font-weight: bold; background: #f5f7fa; border-top: 1px solid #aaa; border-bottom: 2px solid #333; }

tfoot tr td { font-weight: bold; border-top: 2px solid #333; }
.report-empty { padding: 48px 0; text-align: center; color: #888; font-size: 14px; }
.region-title { font-size: 13px; font-weight: bold; margin: 28px 0 0; color: #1e3a5f; border-bottom: 2px solid #1e3a5f; padding-bottom: 3px; }
</style></head>
<body><div class="report-container">

  <div class="report-header">
    <div class="report-title">{{meta.title}}</div>
  </div>

  <div class="report-info-grid">
    <div><span>From Date: </span><strong>{{formatDateDisplay meta.params.dateFrom}}</strong></div>
    <div><span>To Date: </span><strong>{{formatDateDisplay meta.params.dateTo}}</strong></div>
    <div><span>Date Type: </span><strong>{{#if (eq meta.params.dateType 'acct')}}Accounting Date{{else}}Operation Date{{/if}}</strong></div>
    {{#if meta.params._display_currencyId}}
    <div><span>Currency: </span><strong>{{meta.params._display_currencyId}}</strong></div>
    {{/if}}
    {{#if meta.params._display_bPartnerId}}
    <div><span>Business Partner: </span><strong>{{meta.params._display_bPartnerId}}</strong></div>
    {{/if}}
    <div><span>Transaction Type: </span><strong>
      {{#if (eq meta.params.transactionType 'S')}}Sales / Receipts
      {{else}}{{#if (eq meta.params.transactionType 'P')}}Purchases / Payments
      {{else}}Both{{/if}}{{/if}}
    </strong></div>
  </div>

  {{!-- ================================================================ --}}
  {{!-- REGION 1: DETAIL                                                 --}}
  {{!-- ================================================================ --}}
  {{#if meta.showDetails}}
  <div class="region-title">Detail</div>

  {{#if (eq meta.params.transactionType 'P')}}
    {{#if rows.purchase.detail.length}}
      {{> detailSection sectionRows=rows.purchase.detail label="Purchases / Payments" groupByBp=meta.groupByBp}}
    {{/if}}
  {{/if}}
  {{#if (eq meta.params.transactionType 'S')}}
    {{#if rows.sales.detail.length}}
      {{> detailSection sectionRows=rows.sales.detail label="Sales / Receipts" groupByBp=meta.groupByBp}}
    {{/if}}
  {{/if}}
  {{#if (eq meta.params.transactionType 'B')}}
    {{#if rows.purchase.detail.length}}
      {{> detailSection sectionRows=rows.purchase.detail label="Purchases / Payments" groupByBp=meta.groupByBp}}
    {{/if}}
    {{#if rows.sales.detail.length}}
      {{> detailSection sectionRows=rows.sales.detail label="Sales / Receipts" groupByBp=meta.groupByBp}}
    {{/if}}
  {{/if}}

  {{/if}}

  {{!-- ================================================================ --}}
  {{!-- REGION 2: SUMMARY BY TAX CATEGORY                               --}}
  {{!-- ================================================================ --}}
  <div class="region-title">Summary by Tax Category</div>

  {{#if (eq meta.params.transactionType 'P')}}
    {{#if rows.purchase.summaryByCategory.length}}{{> categorySection groups=rows.purchase.summaryByCategory label="Purchases / Payments"}}{{/if}}
  {{/if}}
  {{#if (eq meta.params.transactionType 'S')}}
    {{#if rows.sales.summaryByCategory.length}}{{> categorySection groups=rows.sales.summaryByCategory label="Sales / Receipts"}}{{/if}}
  {{/if}}
  {{#if (eq meta.params.transactionType 'B')}}
    {{#if rows.purchase.summaryByCategory.length}}{{> categorySection groups=rows.purchase.summaryByCategory label="Purchases / Payments"}}{{/if}}
    {{#if rows.sales.summaryByCategory.length}}{{> categorySection groups=rows.sales.summaryByCategory label="Sales / Receipts"}}{{/if}}
  {{/if}}

  {{!-- ================================================================ --}}
  {{!-- REGION 3: SUMMARY BY TAX RATE                                   --}}
  {{!-- ================================================================ --}}
  <div class="region-title">Summary by Tax Rate</div>

  {{#if (eq meta.params.transactionType 'P')}}
    {{#if rows.purchase.summaryByRate.length}}{{> rateSection groups=rows.purchase.summaryByRate label="Purchases / Payments"}}{{/if}}
  {{/if}}
  {{#if (eq meta.params.transactionType 'S')}}
    {{#if rows.sales.summaryByRate.length}}{{> rateSection groups=rows.sales.summaryByRate label="Sales / Receipts"}}{{/if}}
  {{/if}}
  {{#if (eq meta.params.transactionType 'B')}}
    {{#if rows.purchase.summaryByRate.length}}{{> rateSection groups=rows.purchase.summaryByRate label="Purchases / Payments"}}{{/if}}
    {{#if rows.sales.summaryByRate.length}}{{> rateSection groups=rows.sales.summaryByRate label="Sales / Receipts"}}{{/if}}
  {{/if}}

  <div class="report-footer">
    <div>Generated by Etendo Go</div>
  </div>

</div>

{{!-- ================================================================ --}}
{{!-- PARTIAL: Detail table (pre-grouped by tax, optionally by BP)      --}}
{{!-- ================================================================ --}}
{{#*inline "detailSection"}}
<div class="section-banner">{{label}}</div>
<table class="report-table">
  <thead><tr>
    <th style="width:16%">Tax Name</th>
    <th style="width:9%">Doc No.</th>
    <th style="width:8%">Doc Type</th>
    <th style="width:8%">Doc Date</th>
    <th style="width:8%">Acct Date</th>
    <th style="width:14%">Business Partner</th>
    <th style="width:6%">Country</th>
    <th style="width:6%">Region</th>
    <th style="width:8%" class="cell-amount">Tax Base</th>
    <th style="width:8%" class="cell-amount">Tax Amt.</th>
    <th style="width:9%" class="cell-amount">Total</th>
  </tr></thead>
  <tbody>
    {{#each sectionRows}}
    <tr class="tax-group-header">
      <td>{{taxName}}</td>
      <td></td><td></td><td></td><td></td><td></td><td></td><td></td>
      <td class="cell-amount">{{formatCurrency taxBaseAmt}}</td>
      <td class="cell-amount">{{formatCurrency taxAmt}}</td>
      <td class="cell-amount">{{formatCurrency totalAmt}}</td>
    </tr>
    {{#if @root.meta.groupByBp}}
      {{#each bpGroups}}
      <tr class="bp-header-row"><td></td><td colspan="10">{{bPartner}}</td></tr>
      {{#each docs}}<tr class="doc-row">
        <td></td>
        <td><span class="doc-link" onclick="window.parent.postMessage({type:'navigate-invoice',invoiceId:'{{invoiceId}}'},'*')">{{docNo}}</span></td>
        <td>{{docType}}</td>
        <td>{{formatDateDisplay docDate}}</td>
        <td>{{formatDateDisplay acctDate}}</td>
        <td></td>
        <td>{{bpCountry}}</td>
        <td>{{bpRegion}}</td>
        <td class="cell-amount">{{formatCurrency taxBaseAmt}}</td>
        <td class="cell-amount">{{formatCurrency taxAmt}}</td>
        <td class="cell-amount">{{formatCurrency totalAmt}}</td>
      </tr>{{/each}}
      <tr class="bp-total-row">
        <td></td><td colspan="7">Total {{bPartner}}</td>
        <td class="cell-amount">{{formatCurrency taxBaseAmt}}</td>
        <td class="cell-amount">{{formatCurrency taxAmt}}</td>
        <td class="cell-amount">{{formatCurrency totalAmt}}</td>
      </tr>
      {{/each}}
    {{else}}
      {{#each docs}}<tr class="doc-row">
        <td></td>
        <td><span class="doc-link" onclick="window.parent.postMessage({type:'navigate-invoice',invoiceId:'{{invoiceId}}'},'*')">{{docNo}}</span></td>
        <td>{{docType}}</td>
        <td>{{formatDateDisplay docDate}}</td>
        <td>{{formatDateDisplay acctDate}}</td>
        <td>{{bPartner}}</td>
        <td>{{bpCountry}}</td>
        <td>{{bpRegion}}</td>
        <td class="cell-amount">{{formatCurrency taxBaseAmt}}</td>
        <td class="cell-amount">{{formatCurrency taxAmt}}</td>
        <td class="cell-amount">{{formatCurrency totalAmt}}</td>
      </tr>{{/each}}
    {{/if}}
    <tr class="tax-group-total">
      <td colspan="8">Total {{taxName}}</td>
      <td class="cell-amount">{{formatCurrency taxBaseAmt}}</td>
      <td class="cell-amount">{{formatCurrency taxAmt}}</td>
      <td class="cell-amount">{{formatCurrency totalAmt}}</td>
    </tr>
    {{/each}}
  </tbody>
  <tfoot><tr>
    <td colspan="8">TOTAL:</td>
    <td class="cell-amount">{{formatCurrency (sumField sectionRows 'taxBaseAmt')}}</td>
    <td class="cell-amount">{{formatCurrency (sumField sectionRows 'taxAmt')}}</td>
    <td class="cell-amount">{{formatCurrency (sumField sectionRows 'totalAmt')}}</td>
  </tr></tfoot>
</table>
{{/inline}}

{{!-- ================================================================ --}}
{{!-- PARTIAL: Summary by Tax Category                                  --}}
{{!-- ================================================================ --}}
{{#*inline "categorySection"}}
<div class="section-banner">{{label}}</div>
<table class="report-table">
  <thead><tr>
    <th style="width:28%">Tax Name</th>
    <th style="width:8%" class="cell-amount">Rate %</th>
    <th style="width:16%" class="cell-amount">Tax Base</th>
    <th style="width:16%" class="cell-amount">Tax Amount</th>
    <th style="width:16%" class="cell-amount">Total</th>
    <th style="width:10%" class="cell-amount">No. Partners</th>
  </tr></thead>
  <tbody>
    {{#each groups}}
    <tr class="cat-header"><td colspan="6">Total by Tax Category - {{taxCategoryName}}</td></tr>
    {{#each taxes}}<tr class="cat-row">
      <td>{{taxName}}</td>
      <td class="cell-amount">{{formatNumber rate}}</td>
      <td class="cell-amount">{{formatCurrency taxBaseAmt}}</td>
      <td class="cell-amount">{{formatCurrency taxAmt}}</td>
      <td class="cell-amount">{{formatCurrency totalAmt}}</td>
      <td class="cell-amount">{{bpCount}}</td>
    </tr>{{/each}}
    <tr class="cat-total">
      <td colspan="2">TOTALS</td>
      <td class="cell-amount">{{formatCurrency (sumField taxes 'taxBaseAmt')}}</td>
      <td class="cell-amount">{{formatCurrency (sumField taxes 'taxAmt')}}</td>
      <td class="cell-amount">{{formatCurrency (sumField taxes 'totalAmt')}}</td>
      <td></td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{/inline}}

{{!-- ================================================================ --}}
{{!-- PARTIAL: Summary by Tax Rate                                      --}}
{{!-- ================================================================ --}}
{{#*inline "rateSection"}}
<div class="section-banner">{{label}}</div>
<table class="report-table">
  <thead><tr>
    <th style="width:26%">Business Partner / Tax Name</th>
    <th style="width:8%" class="cell-amount">Rate %</th>
    <th style="width:16%" class="cell-amount">Tax Base</th>
    <th style="width:16%" class="cell-amount">Tax Amount</th>
    <th style="width:16%" class="cell-amount">Total</th>
    <th style="width:10%" class="cell-amount">No. Partners</th>
  </tr></thead>
  <tbody>
    {{#each groups}}
    <tr class="rate-header"><td colspan="6">{{formatNumber rate}}%</td></tr>
    {{#each bpGroups}}
    <tr class="bp-header-row">
      <td colspan="2"><strong>{{bPartner}}</strong>{{#if bpTaxId}} <span style="color:#666;font-size:10px;">Tax ID: {{bpTaxId}}</span>{{/if}}</td>
      <td class="cell-amount">{{formatCurrency taxBaseAmt}}</td>
      <td class="cell-amount">{{formatCurrency taxAmt}}</td>
      <td class="cell-amount">{{formatCurrency totalAmt}}</td>
      <td class="cell-amount">1</td>
    </tr>
    {{#each taxes}}<tr class="rate-row">
      <td style="padding-left:20px">{{taxName}}</td>
      <td class="cell-amount">{{formatNumber rate}}</td>
      <td class="cell-amount">{{formatCurrency taxBaseAmt}}</td>
      <td class="cell-amount">{{formatCurrency taxAmt}}</td>
      <td class="cell-amount">{{formatCurrency totalAmt}}</td>
      <td></td>
    </tr>{{/each}}
    {{/each}}
    <tr class="rate-total">
      <td colspan="2">TOTALS</td>
      <td class="cell-amount">{{formatCurrency taxBaseAmt}}</td>
      <td class="cell-amount">{{formatCurrency taxAmt}}</td>
      <td class="cell-amount">{{formatCurrency totalAmt}}</td>
      <td class="cell-amount">{{bpCount}}</td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{/inline}}

</body></html>
