{
  "$schema": "decisions-v2",
  "window": {
    "category": "contact",
    "name": "Contacts",
    "entityLabel": "Contact",
    "sidebarLayout": true,
    "breadcrumb": "Contact",
    "detailEntity": null,
    "summaryFields": [],
    "primaryTabs": [
      {
        "key": "general",
        "label": "General"
      },
      {
        "key": "financial",
        "label": "Financial",
        "panel": "ContactsFinancialPanel"
      }
    ],
    "subsetFilters": [
      {
        "label": "all"
      },
      {
        "label": "customers",
        "filter": "criteria=%5B%7B%22fieldName%22%3A%22customer%22%2C%22operator%22%3A%22equals%22%2C%22value%22%3Atrue%7D%5D"
      },
      {
        "label": "vendors",
        "filter": "criteria=%5B%7B%22fieldName%22%3A%22vendor%22%2C%22operator%22%3A%22equals%22%2C%22value%22%3Atrue%7D%5D"
      }
    ],
    "customComponents": {
      "headerTable": "ContactsTable",
      "topbarExtra": "ContactTypeToggle"
    },
    "hidePrint": true,
    "hideMoreMenu": true,
    "linesLayout": "inlineEditable",
    "labelOverrides": {
      "en_US": {
        "Name": "Legal Name",
        "FIN_Financial_Account_ID": "Account",
        "PO_Financial_Account_ID": "Expense Account",
        "EM_Etgo_Web": "Website",
        "EM_Etgo_Firstname": "First Name",
        "EM_Etgo_Lastname": "Last Name"
      },
      "es_ES": {
        "Name": "Razón Social",
        "EM_Etgo_Identifier": "Identificador",
        "FIN_Financial_Account_ID": "Cuenta",
        "PO_Financial_Account_ID": "Cuenta contable de gastos",
        "EM_Etgo_Web": "Página web",
        "EM_Etgo_Firstname": "Nombre",
        "EM_Etgo_Lastname": "Apellidos"
      }
    },
    "processOverrides": {
      "setNewCurrency": {
        "exclude": true
      }
    },
    "listBaseFilter": "criteria=%7B%22operator%22%3A%22or%22%2C%22criteria%22%3A%5B%7B%22fieldName%22%3A%22customer%22%2C%22operator%22%3A%22equals%22%2C%22value%22%3Atrue%7D%2C%7B%22fieldName%22%3A%22vendor%22%2C%22operator%22%3A%22equals%22%2C%22value%22%3Atrue%7D%5D%7D",
    "listViewOptions": {
      "hidePrint": true,
      "hideEye": true,
      "hideCounter": true,
      "hideLink": true
    },
    "secondaryTabs": {
      "contact": {
        "tabMode": "table-form",
        "tabOrder": 1,
        "label": "Person",
        "addLineFields": [
          "firstName",
          "lastName",
          "email",
          "phone",
          "position"
        ],
        "requireSavedRecord": true
      },
      "bankAccount": {
        "tabMode": "table-form",
        "tabOrder": 2,
        "label": "Bank Account",
        "addLineFields": [
          "bankName",
          "country",
          "bankFormat",
          "accountNo",
          "iBAN",
          "swiftCode"
        ],
        "requireSavedRecord": true
      },
      "locationAddress": {
        "tabOrder": 3,
        "label": "Location",
        "customAddModal": "LocationEditorModal",
        "requireSavedRecord": true
      }
    }
