{
  "version": "0.1.0",
  "window": {
    "id": "800161",
    "name": "Manage Requisitions",
    "primaryEntity": "requisition",
    "category": "procurement",
    "notes": "Management/approval view over the same M_Requisition table. Distinguished from the Requisition window by: (1) broader org-level visibility via tab WHERE clause, (2) approval/rejection workflow actions, (3) Create PO from Requisition process, (4) most header fields are readOnly since managers review rather than create."
  },
  "entities": [
    {
      "name": "requisition",
      "tableName": "M_Requisition",
      "tabWhereClause": "M_Requisition.DocStatus IN ('CO','CL','VO','IP','PE')",
      "tabNotes": "Unlike the Requisition window which shows all statuses for the creator, this management view typically filters to submitted/completed requisitions awaiting management action. The exact HQL clause may vary by Etendo version.",
      "fields": [
        { "name": "documentNo", "column": "DocumentNo", "type": "string", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "docStatus", "column": "DocStatus", "type": "string", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "businessPartner", "column": "C_BPartner_ID", "type": "foreignKey", "reference": "BusinessPartner", "inputMode": "search", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": true },
        { "name": "dateRequired", "column": "DateRequired", "type": "date", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "dateDoc", "column": "DateDoc", "type": "date", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "warehouse", "column": "M_Warehouse_ID", "type": "foreignKey", "reference": "Warehouse", "inputMode": "selector", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "priceList", "column": "M_PriceList_ID", "type": "foreignKey", "reference": "PriceList", "inputMode": "selector", "visibility": "readOnly", "required": true, "grid": false, "form": true, "searchable": false },
        { "name": "totalLines", "column": "TotalLines", "type": "amount", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false },
        { "name": "grandTotal", "column": "GrandTotal", "type": "amount", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false },
        { "name": "user", "column": "AD_User_ID", "type": "foreignKey", "reference": "User", "inputMode": "search", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": true, "notes": "The user who created the requisition. Key field for the management view — allows filtering by requester." },
        { "name": "organization", "column": "AD_Org_ID", "type": "foreignKey", "reference": "Organization", "inputMode": "selector", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true, "notes": "Visible in management view (unlike Requisition window where it is system). Managers need to filter by organization." },
        { "name": "description", "column": "Description", "type": "string", "visibility": "readOnly", "required": false, "grid": false, "form": true, "searchable": true },
        { "name": "cCurrencyId", "column": "C_Currency_ID", "type": "foreignKey", "reference": "Currency", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": false },
        { "name": "isActive", "column": "IsActive", "type": "boolean", "visibility": "readOnly", "required": true, "grid": false, "form": true, "searchable": false },

        { "name": "adClientId", "column": "AD_Client_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.client" } },
        { "name": "cDocTypeId", "column": "C_DocType_ID", "type": "foreignKey", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "doctype.requisition" } },
        { "name": "processed", "column": "Processed", "type": "boolean", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "docStatus === 'CO' ? true : false" } },
        { "name": "created", "column": "Created", "type": "datetime", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "now()" } },
        { "name": "updated", "column": "Updated", "type": "datetime", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "now()" } }
      ]
    },
    {
      "name": "requisitionLine",
      "tableName": "M_RequisitionLine",
      "tabNotes": "Lines are readOnly in the management view. Managers inspect line details but do not modify them.",
      "fields": [
        { "name": "lineNo", "column": "Line", "type": "integer", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": false },
        { "name": "product", "column": "M_Product_ID", "type": "foreignKey", "reference": "Product", "inputMode": "search", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "quantity", "column": "Qty", "type": "number", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": false },
        { "name": "unitPrice", "column": "PriceActual", "type": "amount", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": false },
        { "name": "lineNetAmount", "column": "LineNetAmt", "type": "amount", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false },
        { "name": "needByDate", "column": "NeedByDate", "type": "date", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false },
        { "name": "businessPartner", "column": "C_BPartner_ID", "type": "foreignKey", "reference": "BusinessPartner", "inputMode": "search", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false, "notes": "Preferred vendor for this line — may differ from the header BP." },
        { "name": "uom", "column": "C_UOM_ID", "type": "foreignKey", "reference": "UOM", "inputMode": "selector", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false },
        { "name": "description", "column": "Description", "type": "string", "visibility": "readOnly", "required": false, "grid": false, "form": true, "searchable": false },
        { "name": "matchedPOQty", "column": "Orderedqty", "type": "number", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false, "notes": "Quantity already ordered via Purchase Order. Key management field — shows fulfillment progress." },
        { "name": "requisitionOrder", "column": "M_Requisitionorder_ID", "type": "foreignKey", "reference": "RequisitionOrder", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false, "notes": "Link to the Purchase Order generated from this requisition line. Null if not yet converted." },

        { "name": "adClientId", "column": "AD_Client_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.client" } },
        { "name": "adOrgId", "column": "AD_Org_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.organization" } },
        { "name": "mRequisitionId", "column": "M_Requisition_ID", "type": "foreignKey", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromParent", "source": "requisition.id" } },
        { "name": "cCurrencyId", "column": "C_Currency_ID", "type": "foreignKey", "visibility": "system", "required": false, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromParent", "source": "requisition.cCurrencyId" } }
      ]
    }
  ],
  "processes": [
    {
      "name": "DocAction",
      "type": "classic_process",
      "mechanism": "DocAction button (AD_Column.AD_Process_ID)",
      "description": "Standard document action (Complete, Void, Close, Reactivate). In the management view, the key actions are Complete (approve) and Void (reject).",
      "entity": "requisition"
    },
    {
      "name": "CreatePOFromRequisition",
      "type": "obuiapp_process",
      "mechanism": "Toolbar process or button",
      "description": "Convert approved requisition lines into Purchase Order(s). Groups lines by vendor and creates one PO per vendor. This is the primary management action that distinguishes this window from the basic Requisition window.",
      "entity": "requisition",
      "multiRecord": true
    }
  ]
}
