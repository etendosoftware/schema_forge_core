        "destructive": true,
        "visibleWhenStatus": "CO"
      },
      {
        "key": "reactivate",
        "label": "Reactivate",
        "labelKey": "reactivate",
        "visibleWhenStatus": "CO",
        "documentAction": "RE",
        "successKey": "actionCompleted"
      }
    ],
    "secondaryTabs": {},
