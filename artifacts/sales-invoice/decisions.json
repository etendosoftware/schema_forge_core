  "$schema": "decisions-v2",
  "window": {
    "category": "sales",
    "name": "Sales Invoice",
    "salesTheme": true,
    "lineEntityConfig": "invoice",
    "relatedDocuments": true,
    "notesField": "description",
    "hideDeleteWhenComplete": true,
    "hidePrint": true,
    "customComponents": {
