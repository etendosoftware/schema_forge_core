{
  "version": 1,
  "reportId": "aging-payable",
  "category": "finance",
  "type": "listing",
  "source": "neo",
  "title": { "en_US": "Aging of Payables", "es_ES": "Antigüedad de Pagos" },
  "orientation": "landscape",
  "neo": {
    "endpoint": "/sws/neo/aging-receivable",
    "method": "POST",
    "body": { "recOrPay": "PAYABLES" },
    "dataPath": "response.data",
    "handler": "agingReportHandler"
  },
  "columns": [
    { "field": "bPartner", "label": { "en_US": "Vendor", "es_ES": "Proveedor" }, "type": "string", "width": "25%", "sortable": true },
    { "field": "current", "label": { "en_US": "Current", "es_ES": "Corriente" }, "type": "amount", "width": "12%", "sortable": true },
    { "field": "days30", "label": { "en_US": "1-30 Days", "es_ES": "1-30 Días" }, "type": "amount", "width": "12%", "sortable": true },
    { "field": "days60", "label": { "en_US": "31-60 Days", "es_ES": "31-60 Días" }, "type": "amount", "width": "12%", "sortable": true },
    { "field": "days90", "label": { "en_US": "61-90 Days", "es_ES": "61-90 Días" }, "type": "amount", "width": "12%", "sortable": true },
    { "field": "days120", "label": { "en_US": "91-120 Days", "es_ES": "91-120 Días" }, "type": "amount", "width": "12%", "sortable": true },
    { "field": "total", "label": { "en_US": "Total", "es_ES": "Total" }, "type": "amount", "width": "12%", "sortable": true }
  ],
  "groups": [],
  "filters": [],
  "defaultSort": { "field": "bPartner", "direction": "asc" },
  "outputs": ["pdf", "xlsx", "csv", "html"],
  "summary": { "totalRows": true },
  "mockDataFile": "mock-data.json"
}
