{{!-- Aging of Payables --}}
<!DOCTYPE html>
<html><head><meta charset="UTF-8"><style>
{{{css}}}
.report-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 40px; margin: 8px 0 16px; font-size: 12px; }
.report-info-grid span { color: #555; }
.report-info-grid strong { color: #111; }
tfoot tr td { font-weight: bold; border-top: 2px solid #333; }
</style></head>
<body><div class="report-container">

  <div class="report-header">
    <div class="report-title">{{meta.title}}</div>
  </div>

  <div class="report-info-grid">
    {{#if meta.params._display_orgId}}
    <div><span>Organization: </span><strong>{{meta.params._display_orgId}}</strong></div>
    {{/if}}
    <div><span>As of Date: </span><strong>{{formatDateDisplay meta.params.currentDate}}</strong></div>
    {{#if meta.params._display_glId}}
    <div><span>General Ledger: </span><strong>{{meta.params._display_glId}}</strong></div>
    {{/if}}
    {{#if meta.params._display_bPartnerId}}
    <div><span>Contacts: </span><strong>{{meta.params._display_bPartnerId}}</strong></div>
    {{/if}}
  </div>

  <table class="report-table">
    <thead><tr>
      <th style="width:20%">Contacts</th>
      <th style="width:10%" class="cell-amount">Current</th>
      <th style="width:9%" class="cell-amount">1-{{meta.params.column1}}</th>
      <th style="width:9%" class="cell-amount">{{meta.params.column1}}-{{meta.params.column2}}</th>
      <th style="width:9%" class="cell-amount">{{meta.params.column2}}-{{meta.params.column3}}</th>
      <th style="width:9%" class="cell-amount">{{meta.params.column3}}-{{meta.params.column4}}</th>
      <th style="width:9%" class="cell-amount">&gt;{{meta.params.column4}}</th>
      <th style="width:10%" class="cell-amount">Total</th>
      <th style="width:8%" class="cell-amount">Credits</th>
      <th style="width:8%" class="cell-amount">Net</th>
    </tr></thead>
    <tbody>
      {{#each rows}}<tr>
        <td>{{lookup this 'bPartner'}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'current')}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'days30')}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'days60')}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'days90')}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'days120')}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'days150plus')}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'total')}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'credits')}}</td>
        <td class="cell-amount">{{formatCurrency (lookup this 'net')}}</td>
      </tr>{{/each}}
    </tbody>
    <tfoot><tr>
      <td>TOTAL:</td>
      <td class="cell-amount">{{formatCurrency (sumField rows 'current')}}</td>
      <td class="cell-amount">{{formatCurrency (sumField rows 'days30')}}</td>
      <td class="cell-amount">{{formatCurrency (sumField rows 'days60')}}</td>
      <td class="cell-amount">{{formatCurrency (sumField rows 'days90')}}</td>
      <td class="cell-amount">{{formatCurrency (sumField rows 'days120')}}</td>
      <td class="cell-amount">{{formatCurrency (sumField rows 'days150plus')}}</td>
      <td class="cell-amount">{{formatCurrency (sumField rows 'total')}}</td>
      <td class="cell-amount">{{formatCurrency (sumField rows 'credits')}}</td>
      <td class="cell-amount">{{formatCurrency (sumField rows 'net')}}</td>
    </tr></tfoot>
  </table>

  <div class="report-footer">
    <div>{{meta.recordCount}} records</div>
    <div>Generated by Etendo Go</div>
  </div>

</div></body></html>
