{
  "version": "0.1.0",
  "window": {
    "id": "53012",
    "name": "Return to Vendor Shipment",
    "primaryEntity": "returnShipment",
    "category": "procurement",
    "whereClause": "M_InOut.IsSOTrx='N' AND M_InOut.MovementType='V-'",
    "notes": "Physical shipment back to vendor. Uses M_InOut with MovementType='V-' (vendor return). Differs from Goods Receipt (V+) in direction. Typically linked to a Return to Vendor (RMA) authorization via M_RMA_ID."
  },
  "entities": [
    {
      "name": "returnShipment",
      "tableName": "M_InOut",
      "fields": [
        { "name": "businessPartner", "column": "C_BPartner_ID", "type": "foreignKey", "reference": "BusinessPartner", "inputMode": "search", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": true, "notes": "Vendor (supplier) to whom goods are being returned. Filter BP where IsVendor='Y'" },
        { "name": "partnerAddress", "column": "C_BPartner_Location_ID", "type": "foreignKey", "reference": "BusinessPartnerLocation", "inputMode": "dependent", "dependsOn": { "field": "businessPartner", "filterKey": "businessPartnerId" }, "visibility": "editable", "required": true, "grid": false, "form": true, "searchable": false },
        { "name": "movementDate", "column": "MovementDate", "type": "date", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "dateAcct", "column": "DateAcct", "type": "date", "visibility": "editable", "required": true, "grid": false, "form": true, "searchable": false },
        { "name": "warehouse", "column": "M_Warehouse_ID", "type": "foreignKey", "reference": "Warehouse", "inputMode": "selector", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "returnReason", "column": "M_RMA_ID", "type": "foreignKey", "reference": "ReturnMaterialAuthorization", "inputMode": "search", "visibility": "editable", "required": false, "grid": true, "form": true, "searchable": true, "notes": "Link to Return to Vendor (RMA) authorization. Optional but typical workflow requires an approved RMA before creating the return shipment." },
        { "name": "orderReference", "column": "C_Order_ID", "type": "foreignKey", "reference": "PurchaseOrder", "inputMode": "search", "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": true, "notes": "Original purchase order reference. May be auto-filled from RMA." },
        { "name": "description", "column": "Description", "type": "string", "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": false },
        { "name": "poReference", "column": "POReference", "type": "string", "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": true },
        { "name": "isActive", "column": "IsActive", "type": "boolean", "visibility": "editable", "required": true, "grid": false, "form": true, "searchable": false },

        { "name": "documentNo", "column": "DocumentNo", "type": "string", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "docStatus", "column": "DocStatus", "type": "string", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true },

        { "name": "adClientId", "column": "AD_Client_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.client" } },
        { "name": "adOrgId", "column": "AD_Org_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.organization" } },
        { "name": "isSotrx", "column": "IsSOTrx", "type": "boolean", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "false" }, "notes": "Always 'N' — this is a purchase-side (vendor) transaction" },
        { "name": "movementType", "column": "MovementType", "type": "string", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "'V-'" }, "notes": "V- = Vendor Return (outbound to vendor). Goods Receipt uses V+ (inbound from vendor)." },
        { "name": "cDocTypeId", "column": "C_DocType_ID", "type": "foreignKey", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "doctype.returnToVendorShipment" } },
        { "name": "processed", "column": "Processed", "type": "boolean", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "docStatus === 'CO' ? true : false" } },
        { "name": "created", "column": "Created", "type": "datetime", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "now()" } },
        { "name": "updated", "column": "Updated", "type": "datetime", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "now()" } }
      ]
    },
    {
      "name": "returnShipmentLine",
      "tableName": "M_InOutLine",
      "fields": [
        { "name": "product", "column": "M_Product_ID", "type": "foreignKey", "reference": "Product", "inputMode": "search", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "movementQty", "column": "MovementQty", "type": "number", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": false, "notes": "Quantity being returned. Positive value — the MovementType V- handles the direction." },
        { "name": "locator", "column": "M_Locator_ID", "type": "foreignKey", "reference": "Locator", "inputMode": "selector", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": false, "notes": "Source storage bin from which goods are taken for return" },
        { "name": "lineNo", "column": "Line", "type": "integer", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": false },
        { "name": "description", "column": "Description", "type": "string", "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": false },
        { "name": "returnOrderLine", "column": "C_OrderLine_ID", "type": "foreignKey", "reference": "PurchaseOrderLine", "inputMode": "dependent", "dependsOn": { "field": "returnShipment.orderReference", "filterKey": "cOrderId" }, "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": false, "notes": "Link to original purchase order line. Enables traceability of which PO line this return corresponds to." },
        { "name": "rmaLine", "column": "M_RMALine_ID", "type": "foreignKey", "reference": "ReturnMaterialAuthorizationLine", "inputMode": "dependent", "dependsOn": { "field": "returnShipment.returnReason", "filterKey": "mRmaId" }, "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": false, "notes": "Link to RMA line. When created from RMA, this is auto-filled." },

        { "name": "uom", "column": "C_UOM_ID", "type": "foreignKey", "reference": "UOM", "inputMode": "selector", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false },

        { "name": "adClientId", "column": "AD_Client_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.client" } },
        { "name": "adOrgId", "column": "AD_Org_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.organization" } },
        { "name": "mInoutId", "column": "M_InOut_ID", "type": "foreignKey", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromParent", "source": "returnShipment.id" } },
        { "name": "movementDate", "column": "MovementDate", "type": "date", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromParent", "source": "returnShipment.movementDate" } },
        { "name": "cBpartnerId", "column": "C_BPartner_ID", "type": "foreignKey", "visibility": "system", "required": false, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromParent", "source": "returnShipment.businessPartner" } },
        { "name": "warehouse", "column": "M_Warehouse_ID", "type": "foreignKey", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromParent", "source": "returnShipment.warehouse" } }
      ]
    }
  ]
}
