{
  "$schema": "decisions-v2",
  "window": {
    "category": "finance",
    "name": "Amortization",
    "breadcrumb": "Finance / Amortization",
    "titleField": "name",
    "sidebarLayout": true,
    "linesLayout": "inlineEditable",
    "hideDeleteWhenComplete": true,
    "hidePrint": true,
    "hideLink": true,
    "toolbarButtonSize": "default",
    "noHeaderBorder": true,
    "whiteFormBackground": true,
    "listbarPaddingX": "px-2",
    "tablePaddingX": "px-2",
    "sidebarClassName": "w-[30%] shrink-0 overflow-y-auto border-l border-[#E8EAEF] p-2",
    "relatedDocuments": false,
    "draftMode": {
      "enabled": true,
      "processField": "Processed",
      "processValue": "Y",
      "label": "confirm",
      "confirmModal": "AmortizationConfirmModal",
      "disableWhenEmpty": true
    },
    "menuActions": [
      {
        "key": "reactivate",
        "label": "Reactivate",
        "labelKey": "reactivate",
        "visibleWhenFieldTrue": "processed",
        "columnName": "Processed"
      }
    ],
    "labelOverrides": {
      "es_ES": {
        "Name": "Nombre",
        "Description": "Descripción",
        "DateAcct": "Fecha contable",
        "StartDate": "Fecha de inicio",
        "Totalamortization": "Amortización total",
        "C_Currency_ID": "Moneda",
        "A_Asset_ID": "Activo",
        "Amortization_Percentage": "% Amortización",
        "Amortizationamt": "Importe amortización",
        "Line": "Nº línea"
      },
      "en_US": {
        "Name": "Name",
        "Description": "Description",
        "DateAcct": "Accounting Date",
        "StartDate": "Starting Date",
        "Totalamortization": "Total Amortization",
        "C_Currency_ID": "Currency",
        "A_Asset_ID": "Asset",
        "Amortization_Percentage": "Amortization %",
        "Amortizationamt": "Amortization Amount",
        "Line": "Line No."
      }
    }
  },
  "entities": {
    "header": {
      "fields": {
        "name": {
          "grid": true,
          "searchable": true,
          "seq": 10
        },
        "description": {
          "form": true,
          "grid": false,
          "seq": 50,
          "section": "principal"
        },
        "accountingDate": {
          "grid": true,
          "searchable": true,
          "seq": 20
        },
        "startingDate": {
          "grid": true,
          "searchable": true,
          "seq": 30
        },
        "totalAmortization": {
          "visibility": "readOnly",
          "grid": true,
          "form": false,
          "seq": 40,
          "columnType": "amount",
          "summable": true
        },
        "currency": {
          "grid": false,
          "form": true,
          "seq": 35,
          "section": "principal",
          "defaultExpr": "@$C_Currency_ID@",
          "inputMode": "selector",
          "reference": "Currency"
        },
        "processed": {
          "visibility": "editable",
          "grid": true,
          "form": false,
          "filterOnly": true,
          "searchable": false,
          "columnType": "status",
          "enumValues": [
            { "value": "N", "name": "statusDraft" },
            { "value": "Y", "name": "statusProcessed" }
          ]
        },
        "project": {
          "visibility": "discarded",
          "reason": "Accounting dimension — out of MVP scope, only visible when @ACCT_DIMENSION_DISPLAY@"
        },
        "salesCampaign": {
          "visibility": "discarded",
          "reason": "Accounting dimension — only visible when @$Element_MC@='Y'"
        },
        "activity": {
          "visibility": "discarded",
          "reason": "Accounting dimension — only visible when @$Element_AY@='Y'"
        },
        "stDimension": {
          "visibility": "discarded",
          "reason": "Accounting dimension — out of MVP scope"
        },
        "ndDimension": {
          "visibility": "discarded",
          "reason": "Accounting dimension — out of MVP scope"
        }
      }
    },
    "lines": {
      "fields": {
        "lineNo": {
          "visibility": "system",
          "reason": "Auto-incremented sequence per parent amortization document"
        },
        "asset": {
          "grid": true,
          "form": true,
          "inputMode": "selector",
          "reference": "Asset",
          "grow": true
        },
        "amortizationPercentage": {
          "grid": true,
          "form": true,
          "grow": true
        },
        "amortizationAmount": {
          "grid": true,
          "form": true,
          "noTrailing": true,
          "required": true
        },
        "currency": {
          "visibility": "readOnly",
          "grid": false,
          "form": false,
          "inputMode": "selector",
          "reference": "Currency",
          "reason": "Inherited from header — shown in the header form, redundant on each line"
        },
        "project": {
          "visibility": "discarded",
          "reason": "Accounting dimension — out of MVP scope"
        },
        "costcenter": {
          "visibility": "discarded",
          "reason": "Accounting dimension — out of MVP scope"
        },
        "stDimension": {
          "visibility": "discarded",
          "reason": "Accounting dimension — out of MVP scope"
        },
        "ndDimension": {
          "visibility": "discarded",
          "reason": "Accounting dimension — out of MVP scope"
        }
      }
    },
    "accounting": {
      "exclude": true
    }
  },
  "rules": {
    "AD_Org show child organizations": {
      "type": "validation",
      "entity": "header",
      "decision": "Keep",
      "description": "Restrict organization selector to child orgs of the active client",
      "reason": "Standard org-tree filter applied everywhere in Etendo — keeping it ensures data consistency"
    },
    "A_Amortization-AD_Org_ID-readOnlyLogic": {
      "type": "readOnlyLogic",
      "entity": "header",
      "decision": "Keep",
      "description": "Lock Organization once processed",
      "reason": "Simple flag check, locks the field after the document is processed"
    },
    "A_Amortization-Name-readOnlyLogic": {
      "type": "readOnlyLogic",
      "entity": "header",
      "decision": "Keep",
      "description": "Lock Name once processed",
      "reason": "Prevents renaming after the document is processed"
    },
    "A_Amortization-Description-readOnlyLogic": {
      "type": "readOnlyLogic",
      "entity": "header",
      "decision": "Keep",
      "description": "Lock Description once processed",
      "reason": "Same processed-lock pattern"
    },
    "A_Amortization-DateAcct-readOnlyLogic": {
      "type": "readOnlyLogic",
      "entity": "header",
      "decision": "Keep",
      "description": "Lock Accounting Date once processed",
      "reason": "Date locks once accounting entry is generated"
    },
    "A_Amortization-StartDate-readOnlyLogic": {
      "type": "readOnlyLogic",
      "entity": "header",
      "decision": "Keep",
      "description": "Lock Starting Date once processed",
      "reason": "Date locks once accounting entry is generated"
    },
    "A_Amortization-Totalamortization-readOnlyLogic": {
      "type": "readOnlyLogic",
      "entity": "header",
      "decision": "Keep",
      "description": "Lock Total Amortization once processed",
      "reason": "Computed total locks with the rest of the document"
    },
    "A_Amortization-C_Currency_ID-readOnlyLogic": {
      "type": "readOnlyLogic",
      "entity": "header",
      "decision": "Keep",
      "description": "Lock Currency once processed",
      "reason": "Currency cannot change once amortization lines exist"
    },
    "A_Amortization-AD_Client_ID-readOnlyLogic": {
      "type": "readOnlyLogic",
      "entity": "header",
      "decision": "Keep",
      "description": "Lock Client once processed",
      "reason": "Standard processed-lock applied to all internal-category columns"
