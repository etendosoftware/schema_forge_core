{
  "version": 1,
  "reportId": "balance-sheet",
  "category": "finance",
  "type": "grouped-listing",
  "source": "sql",
  "title": { "en_US": "Balance Sheet", "es_ES": "Balance General" },
  "orientation": "portrait",
  "sql": {
    "query": "SELECT CASE ev.accounttype WHEN 'A' THEN '1. Assets' WHEN 'L' THEN '2. Liabilities' WHEN 'O' THEN '3. Equity' END AS category, ev.value || ' - ' || ev.name AS account, SUM(fa.amtacctdr) - SUM(fa.amtacctcr) AS amount FROM fact_acct fa JOIN c_elementvalue ev ON ev.c_elementvalue_id = fa.account_id LEFT JOIN c_period cper ON cper.c_period_id = fa.c_period_id WHERE fa.ad_client_id IN ('__CLIENT_ID__') AND fa.factaccttype NOT IN ('R', 'C') AND ev.accounttype IN ('A', 'L', 'O') AND ev.elementlevel = '__ACCOUNTLEVEL__' AND ('__YEARID__' = '' OR cper.c_year_id = '__YEARID__') AND ('__ORGID__' = '' OR fa.ad_org_id = '__ORGID__') AND ('__ACCTSCHEMAID__' = '' OR fa.c_acctschema_id = '__ACCTSCHEMAID__') GROUP BY ev.accounttype, ev.value, ev.name HAVING ('__SHOWONLYWITHVALUE__' = 'false' OR ABS(SUM(fa.amtacctdr) - SUM(fa.amtacctcr)) > 0.01) ORDER BY category, ev.value"
  },
  "columns": [
    { "field": "account", "label": { "en_US": "Account", "es_ES": "Cuenta" }, "type": "string", "width": "55%", "sortable": true },
    { "field": "amount", "label": { "en_US": "Balance", "es_ES": "Saldo" }, "type": "amount", "width": "25%", "sortable": true }
  ],
  "groups": [
    { "field": "category", "label": { "en_US": "Category", "es_ES": "Categoría" } }
  ],
  "parameters": [
    { "name": "acctSchemaId",     "label": { "en_US": "General Ledger",                "es_ES": "Contabilidad" },            "type": "search",  "selector": "accounting", "inputStyle": "modal", "required": true, "autoDefault": true, "section": "primary" },
    { "name": "orgId",            "label": { "en_US": "Organization",                  "es_ES": "Organización" },            "type": "search",  "selector": "org-bs",     "inputStyle": "modal", "required": true, "autoDefault": true, "section": "primary" },
    { "name": "yearId",           "label": { "en_US": "Year",                          "es_ES": "Año" },                     "type": "search",  "selector": "year", "inputStyle": "modal", "required": true, "autoDefault": true, "dependsOn": "orgId", "section": "primary" },
    { "name": "accountLevel",     "label": { "en_US": "Account Level",                 "es_ES": "Nivel de Cuenta" },         "type": "select",  "options": [{ "value": "A", "label": "Account" }, { "value": "B", "label": "Breakdown" }, { "value": "H", "label": "Heading" }, { "value": "S", "label": "Subaccount" }], "default": "A", "section": "primary" },
    { "name": "showOnlyWithValue","label": { "en_US": "Show only accounts with value", "es_ES": "Solo cuentas con saldo" }, "type": "boolean", "default": "true",  "section": "options" },
    { "name": "showLandscape",    "label": { "en_US": "Show Landscape mode",           "es_ES": "Modo horizontal" },         "type": "boolean", "section": "options" }
  ],
  "defaultSort": { "field": "account", "direction": "asc" },
  "outputs": ["pdf", "xlsx", "csv", "html"],
  "summary": { "totalRows": true },
  "mockDataFile": "mock-data.json"
}
