{
  "$schema": "decisions-v2",
  "window": {
    "category": "inventory",
    "name": "Product Category",
    "detailEntity": "accounting",
    "linesLayout": "inlineEditable",
    "formCardPadding": "p-2",
    "toolbarPaddingX": "px-2",
    "tabsBarPaddingX": "px-2",
    "formScrollPaddingX": "px-2",
    "noHeaderBorder": true,
    "toolbarBorderBottom": true
  },
  "entities": {
    "productCategory": {
      "fields": {
        "searchKey": {
          "grid": true,
          "searchable": true,
          "section": "principal",
          "seq": 1
        },
        "name": {
          "grid": true,
          "searchable": true,
          "section": "principal",
          "seq": 2
        },
        "description": {
          "type": "textarea",
          "section": "principal",
          "seq": 3,
          "span": 2,
          "rows": 1
        },
        "default": {
          "section": "principal",
          "seq": 4
        },
        "summaryLevel": {
          "section": "principal",
          "seq": 5
        },
        "image": {
          "visibility": "discarded"
        },
        "plannedMargin": {
          "visibility": "discarded"
        },
        "assetCategory": {
          "visibility": "discarded"
        }
      }
    },
    "accounting": {
      "fields": {
        "accountingSchema": { "visibility": "discarded" },
        "fixedAsset": {
          "visibility": "editable",
          "grid": true,
          "seq": 1
        },
        "productExpense": {
          "visibility": "editable",
          "grid": true,
          "grow": true,
          "seq": 2
        },
        "productRevenue": {
          "visibility": "editable",
          "grid": true,
          "grow": true,
          "seq": 3
        },
        "productCOGS": {
          "visibility": "editable",
          "grid": true,
          "grow": true,
          "seq": 4
        },
        "pDefExpenseAcct": {
          "visibility": "discarded"
        },
        "productDeferredRevenue": {
          "visibility": "discarded"
        },
        "invoicePriceVariance": {
          "visibility": "discarded"
        },
        "productRevenueReturn": {
          "visibility": "discarded"
        },
        "productCOGSReturn": {
          "visibility": "discarded"
        },
        "purchasePriceVariance": {
          "visibility": "discarded"
        },
        "tradeDiscountReceived": {
          "visibility": "discarded"
        },
        "tradeDiscountGranted": {
          "visibility": "discarded"
        },
        "processNow": {
          "visibility": "discarded"
        }
      }
    },
    "assignedProducts": {
      "exclude": true
    },
    "translation": {
      "exclude": true
    }
  },
  "rules": {},
  "discardPatterns": ["EM_*"],
  "version": 2
}
