{
  "$schema": "decisions-v2",
  "window": {
    "category": "inventory",
    "name": "Warehouse",
    "detailEntity": null,
    "secondaryTabs": {
      "productTransactions": {
        "label": "Transactions",
        "customPanel": "WarehouseTransactionsTable"
      }
    },
    "hidePrint": true,
    "hideLink": true,
    "listbarPaddingX": "px-2",
    "tablePaddingX": "px-2"
  },
  "entities": {
    "header": {
      "name": "warehouse",
      "fields": {
        "searchKey": {
          "searchable": true,
          "grid": true,
          "seq": 1
        },
        "name": {
          "searchable": true,
          "grid": true,
          "seq": 2
        },
        "description": {
          "grid": false,
          "seq": 4,
          "span": 4,
          "rows": 1
        },
        "locationAddress": {
          "grid": true,
          "seq": 3,
          "span": 2
        },
        "warehouseRule": {
          "grid": false,
          "visibility": "discarded"
        },
        "storageBinSeparator": {
          "visibility": "discarded"
        },
        "shipmentVehicle": {
          "visibility": "discarded"
        },
        "shipperCode": {
          "visibility": "discarded"
        },
        "fromDocumentNo": {
          "visibility": "discarded"
        },
        "toDocumentNo": {
          "visibility": "discarded"
        },
        "mReturnlocatorID": {
          "visibility": "discarded"
        },
        "allocated": {
          "visibility": "discarded"
        }
      },
      "formCols": 4
    },
    "storageBin": {
      "name": "storageBin"
    },
    "productTransactions": {
      "name": "productTransactions"
    },
    "binContents": {
      "name": "binContents"
    },
    "accounting": {
      "name": "accounting",
      "exclude": true
    }
  },
  "rules": {},
  "discardPatterns": [
    "EM_*"
  ],
  "version": 2
}
