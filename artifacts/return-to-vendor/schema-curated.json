{
  "version": "0.1.0",
  "window": {
    "id": "800176",
    "name": "Return to Vendor",
    "primaryEntity": "returnMaterial",
    "category": "procurement"
  },
  "entities": [
    {
      "name": "returnMaterial",
      "tableName": "M_RMA",
      "tabWhereClause": "M_RMA.IsSOTrx='N'",
      "fields": [
        { "name": "businessPartner", "column": "C_BPartner_ID", "type": "foreignKey", "reference": "BusinessPartner", "inputMode": "search", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": true, "notes": "Must be a vendor (IsVendor='Y')" },
        { "name": "documentDate", "column": "DateOrdered", "type": "date", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "returnDate", "column": "DateDelivered", "type": "date", "visibility": "editable", "required": false, "grid": true, "form": true, "searchable": false },
        { "name": "originalReceipt", "column": "InOut_ID", "type": "foreignKey", "reference": "MaterialReceipt", "inputMode": "search", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": true, "notes": "Goods Receipt (M_InOut where IsSOTrx='N' and DocStatus='CO') from the selected vendor" },
        { "name": "warehouse", "column": "M_Warehouse_ID", "type": "foreignKey", "reference": "Warehouse", "inputMode": "selector", "visibility": "editable", "required": true, "grid": false, "form": true, "searchable": false },
        { "name": "returnReason", "column": "Description", "type": "string", "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": true, "notes": "Free-text reason for the return" },
        { "name": "salesRepresentative", "column": "SalesRep_ID", "type": "foreignKey", "reference": "User", "inputMode": "search", "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": false },

        { "name": "documentNo", "column": "DocumentNo", "type": "string", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "docStatus", "column": "DocStatus", "type": "string", "visibility": "readOnly", "required": true, "grid": true, "form": true, "searchable": true },
        { "name": "totalAmount", "column": "Amt", "type": "amount", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false },
        { "name": "isApproved", "column": "IsApproved", "type": "boolean", "visibility": "readOnly", "required": false, "grid": false, "form": true, "searchable": false },

        { "name": "adClientId", "column": "AD_Client_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.client" } },
        { "name": "adOrgId", "column": "AD_Org_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.organization" } },
        { "name": "cDocTypeId", "column": "C_DocType_ID", "type": "foreignKey", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "doctype.returnToVendor" } },
        { "name": "isSotrx", "column": "IsSOTrx", "type": "boolean", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "false" } },
        { "name": "processed", "column": "Processed", "type": "boolean", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "docStatus === 'CO' ? true : false" } },
        { "name": "name", "column": "Name", "type": "string", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "documentNo" } },
        { "name": "created", "column": "Created", "type": "datetime", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "now()" } },
        { "name": "updated", "column": "Updated", "type": "datetime", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "now()" } }
      ]
    },
    {
      "name": "returnMaterialLine",
      "tableName": "M_RMALine",
      "fields": [
        { "name": "originalReceiptLine", "column": "M_InOutLine_ID", "type": "foreignKey", "reference": "MaterialReceiptLine", "inputMode": "selector", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": false, "notes": "Line from the original Goods Receipt. Filters by parent's InOut_ID" },
        { "name": "quantity", "column": "Qty", "type": "number", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": false, "notes": "Cannot exceed original receipt line quantity" },
        { "name": "lineNo", "column": "Line", "type": "integer", "visibility": "editable", "required": true, "grid": true, "form": true, "searchable": false },
        { "name": "description", "column": "Description", "type": "string", "visibility": "editable", "required": false, "grid": false, "form": true, "searchable": false },

        { "name": "product", "column": "M_Product_ID", "type": "foreignKey", "reference": "Product", "inputMode": "search", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": true, "notes": "Auto-filled from selected receipt line" },
        { "name": "uom", "column": "C_UOM_ID", "type": "foreignKey", "reference": "UOM", "inputMode": "selector", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false },
        { "name": "lineAmount", "column": "Amt", "type": "amount", "visibility": "readOnly", "required": false, "grid": true, "form": true, "searchable": false },
        { "name": "tax", "column": "C_Tax_ID", "type": "foreignKey", "reference": "Tax", "inputMode": "selector", "visibility": "readOnly", "required": false, "grid": false, "form": true, "searchable": false },

        { "name": "adClientId", "column": "AD_Client_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.client" } },
        { "name": "adOrgId", "column": "AD_Org_ID", "type": "id", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromConfig", "source": "context.organization" } },
        { "name": "mRmaId", "column": "M_RMA_ID", "type": "foreignKey", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromParent", "source": "returnMaterial.id" } },
        { "name": "isActive", "column": "IsActive", "type": "boolean", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "computed", "expression": "true" } },
        { "name": "processed", "column": "Processed", "type": "boolean", "visibility": "system", "required": true, "grid": false, "form": false, "searchable": false, "derivation": { "type": "fromParent", "source": "returnMaterial.processed" } }
      ]
    }
  ]
}
