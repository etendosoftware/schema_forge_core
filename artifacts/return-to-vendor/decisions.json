{
  "$schema": "decisions-v2",
  "window": {
    "category": "purchases",
    "name": "Return to Vendor",
    "relatedDocuments": true,
    "notesField": "returnReason",
    "dateFilterKey": "orderDate",
    "lineEntityConfig": "returnOrder",
    "linesLayout": "inlineEditable",
    "customComponents": {
      "bottomSection": "ReturnToVendorBottomPanel"
    }
  },
  "entities": {
    "header": {
      "fields": {
        "businessPartner": {
          "grid": true,
          "searchable": true,
          "reference": "BusinessPartner",
          "selectorFilter": "isVendor=Y",
          "section": "principal"
        },
        "partnerAddress": {
          "reference": "BusinessPartnerLocation",
          "inputMode": "dependent",
          "dependsOn": {
            "field": "businessPartner",
            "filterKey": "C_BPartner_ID"
          },
          "section": "principal"
        },
        "priceList": {
          "section": "principal"
        },
        "orderDate": {
          "grid": true
        }
      }
    },
    "lines": {
      "fields": {
        "tax": {
          "grid": true,
          "form": true,
          "section": "principal",
          "inputMode": "selector"
        },
        "lineGrossAmount": {
          "visibility": "readOnly",
          "grid": true,
          "form": true,
          "displayLogic": null
        }
      }
    }
  },
  "rules": {},
  "discardPatterns": [],
  "version": 2
}
