{
  "version": "0.1.0",
  "window": {
    "id": "168",
    "name": "Physical Inventory",
    "primaryEntity": "inventory",
    "category": "warehouse"
  },
  "entities": [
    {
      "name": "inventory",
      "tableName": "M_Inventory",
      "fields": [
