{
  "$schema": "decisions-v2",
  "version": 2,
  "window": {
    "category": "settings",
    "name": "Price List",
    "hidePrint": true,
    "hideMoreMenu": true,
    "showDetailFooterTotals": false,
    "labelOverrides": {
      "es_ES": {
        "Name": "Nombre",
        "C_Currency_ID": "Moneda",
        "Costbased": "Basado en coste",
        "IsTaxIncluded": "Precio incluye impuesto",
        "IsDefault": "Por defecto"
      }
    }
  },
  "entities": {
    "priceList": {
      "fields": {
        "name": {
          "grid": true,
          "searchable": true,
          "section": "principal",
          "seq": 1
        },
        "currency": {
          "grid": true,
          "section": "principal",
          "seq": 2
        },
        "description": {
          "grid": false,
          "section": "principal",
          "seq": 3
        },
        "salesPriceList": {
          "grid": true,
          "section": "principal",
          "seq": 4,
          "badge": true,
          "labels": { "es_ES": "Tipo", "en_US": "Type" },
          "badgeLabels": {
            "true": { "es_ES": "Venta", "en_US": "Sales" },
            "false": { "es_ES": "Compra", "en_US": "Purchase" }
          },
          "badgeVariants": {
            "true": "blue",
            "false": "purple"
          }
        },
        "costBasedPriceList": {
          "grid": false,
          "section": "principal",
          "seq": 5
        },
        "priceIncludesTax": {
          "grid": false,
          "section": "principal",
          "seq": 6
        },
        "default": {
          "grid": false,
          "section": "principal",
          "seq": 7
        },
        "active": {
          "visibility": "discarded"
        },
        "enforcePriceLimit": {
          "visibility": "discarded"
        },
        "basePricelist": {
          "visibility": "discarded"
        }
      }
    },
    "priceListLine": {
      "fields": {
        "product": {
          "grid": true,
          "section": "principal",
          "seq": 1
        },
        "listPrice": {
          "grid": true,
          "section": "principal",
          "seq": 2
        },
        "standardPrice": {
          "grid": true,
          "section": "principal",
          "seq": 3
        },
        "limitPrice": {
          "grid": true,
          "section": "principal",
          "seq": 4
        },
        "uom": {
          "grid": true,
          "section": "principal",
          "seq": 5
        }
      }
    }
  },
  "rules": {},
  "discardPatterns": ["EM_*"]
}
