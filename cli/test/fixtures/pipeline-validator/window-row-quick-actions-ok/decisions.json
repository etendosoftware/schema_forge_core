{
  "$schema": "decisions-v2",
  "version": 2,
  "window": {
    "title": "Sales Order",
    "menuActions": [
      { "key": "duplicateOrder", "label": "Duplicate" },
      { "key": "voidIt", "label": "Void", "destructive": true }
    ],
    "processOverrides": {
      "completeOrder": { "label": "Complete" }
    },
    "rowQuickActions": {
      "enabled": true,
      "actions": {
        "edit": { "show": true },
        "duplicate": { "show": true },
        "email": { "show": true },
        "delete": { "show": true },
        "duplicateOrder": { "show": "kebab" },
        "completeOrder": { "show": "fixed", "visibleWhen": "@DocumentStatus@='DR'" }
      }
    }
  },
  "entities": {
    "sales-order": {
      "fields": {
        "documentNo": { "visibility": "readOnly" }
      }
    }
  },
  "rules": [],
  "discardPatterns": [],
  "excludedEntities": []
}
