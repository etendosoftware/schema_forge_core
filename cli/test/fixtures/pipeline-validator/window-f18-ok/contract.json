              "parts": [
                { "field": "name", "sortable": true, "filterable": true },
                { "field": "searchKey", "sortable": true, "filterable": true }
              ]
            }
          },
          { "name": "searchKey", "column": "Value" },
          { "name": "image", "column": "M_Image_ID" }
        ]
      }
    }
  },
  "agentProfile": {}
}
