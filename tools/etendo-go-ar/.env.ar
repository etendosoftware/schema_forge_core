# Full path to the AR Etendo installation's gradle.properties
# (used by sf-extract-db to read DB credentials)
ETENDO_GRADLE_PROPERTIES=../../etendo_core_ar/gradle.properties

# Etendo AR backend URL — used by Vite dev proxy to forward /sws, /oauth2, /webhooks
# Override per-machine in .env.local (never commit .env.local)
ETENDO_URL=http://localhost:8080/etendo_ar

# Argentina (AR) Localization Module ID
SF_MODULE_ID=48E18B28715944AEBDDDE0FBE3DE8C1F
